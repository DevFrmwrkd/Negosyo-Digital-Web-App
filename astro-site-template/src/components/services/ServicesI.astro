---
/**
 * ServicesI - Meridian Core Specialties
 * Features high-contrast stat blocks and clean, boxed service cards.
 * Minimalist professional consulting aesthetic with soft neutral tones.
 */
interface Props {
  headline: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; icon?: string }>;
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Services',
  subheadline = 'What We Do',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

// Custom Icons for consulting themes
const getIcon = (index: number) => {
  const icons = [
    '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>',
    '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
    '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
    '<line x1="3" y1="21" x2="21" y2="21"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="5 21 5 10 12 3 19 10 19 21"/>'
  ];
  return icons[index % icons.length];
};

const stats = [
  { label: 'Client revenue influenced', value: '$2.5B+' },
  { label: 'Enterprise clients worldwide', value: '500+' },
  { label: 'Client satisfaction rate', value: '98%' },
  { label: 'Industry experience', value: '22yr' }
];
---

<section id="services" class="relative py-24 lg:py-40 bg-[var(--bg)] overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12">
    
    {/* Header Section */}
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-20">
      <div class="max-w-2xl">
        {showSubheadline && (
          <div class="reveal mb-8">
            <span class="px-6 py-2 rounded-full bg-[var(--surface)] border border-[var(--text)]/10 text-[var(--text)] text-[10px] font-bold uppercase tracking-widest">
               {subheadline}
            </span>
          </div>
        )}
        {showHeadline && (
          <h2 class="reveal-delay-1 reveal text-[var(--fs-xl)] lg:text-[var(--fs-2xl)] font-serif leading-[1] text-[var(--text)] tracking-tight">
            {headline}
          </h2>
        )}
      </div>
    </div>

    {/* Services Grid */}
    {showList && (
      <div class="grid md:grid-cols-2 gap-8 mb-32">
        {services.map((service, i) => (
          <div class="reveal group relative p-12 bg-[var(--surface)] rounded-[2rem] border border-[var(--text)]/5 hover:bg-[var(--text)] transition-all duration-700 hover:shadow-2xl hover:-translate-y-2">
            <div class="flex items-center gap-6 mb-10">
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--primary)]/10 text-[var(--primary)] group-hover:bg-[var(--primary)] group-hover:text-[var(--inverse-text)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={getIcon(i)} />
              </div>
              <h3 class="text-[var(--fs-lg)] font-serif text-[var(--text)] group-hover:text-[var(--inverse-text)] transition-colors">
                {service.name}
              </h3>
            </div>
            <p class="text-[var(--fs-base)] text-[var(--text-muted)] leading-loose group-hover:text-[var(--inverse-text)]/60 transition-colors mb-8">
               {service.description}
            </p>
            <a href="#contact" class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--primary)] opacity-0 group-hover:opacity-100 transition-all">
              Learn more
              <svg class="w-3 h-3 translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    )}

    {/* Results Stats Impact Block */}
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 mb-20 text-right">
       <div class="ml-auto">
         <div class="reveal mb-8">
            <span class="px-6 py-2 rounded-full bg-[var(--surface)] text-[var(--text)] text-[10px] font-bold uppercase tracking-widest border border-[var(--text)]/10">
               The Results
            </span>
          </div>
          <h2 class="reveal text-[var(--fs-xl)] lg:text-[var(--fs-2xl)] font-serif leading-[1] text-[var(--text)] tracking-tight">
            Impact at Scale
          </h2>
       </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
       {stats.map((stat, i) => (
         <div class={`reveal transition-all duration-700 p-12 rounded-[2rem] ${i === 0 ? 'bg-[var(--text)] text-[var(--bg)] shadow-2xl scale-105 z-10' : 'bg-[var(--surface)] text-[var(--text)] border border-[var(--text)]/5'}`}>
            <span class="block text-[var(--fs-xl)] font-serif mb-4 leading-none tracking-tighter">
              {stat.value}
            </span>
            <p class={`text-[10px] font-bold uppercase tracking-widest ${i === 0 ? 'opacity-60' : 'text-[var(--text-muted)]'}`}>
              {stat.label}
            </p>
         </div>
       ))}
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
