---
/**
 * ServicesE - Interactive Feature Grid
 * A premium bento-style grid with glassmorphic cards, 
 * adaptive color interactions, and scroll-staggered reveals.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Services',
  subheadline = 'Crafting excellence in every detail',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showBadge = visibility?.servicesBadge !== false;
const showList = visibility?.servicesList !== false;

const serviceIcons: string[] = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
];
---

<section id="services" class="relative py-24 lg:py-32 bg-[var(--bg)]">
  <div class="container mx-auto px-6">
    
    {/* Section Header */}
    <div class="max-w-3xl mb-20">
      {showBadge && (
        <span class="reveal inline-block px-4 py-1.5 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] text-[var(--fs-xs)] font-bold uppercase tracking-widest mb-6">
          Exclusive Offerings
        </span>
      )}
      
      {showHeadline && (
        <h2 class="reveal-delay-1 reveal font-bold leading-tight text-[var(--text)] mb-6"
            style="font-size: var(--fs-2xl); font-family: var(--heading-font);">
          {headline}
        </h2>
      )}
      
      <p class="reveal-delay-2 reveal text-[var(--text-muted)] lg:text-xl max-w-2xl">
        {subheadline}
      </p>
    </div>

    {/* Service Cards Grid */}
    {showList && (
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {services.map((service, index) => (
          <div class={`reveal reveal-delay-${index % 4 + 1} group relative p-8 rounded-[2.5rem] bg-[var(--surface)] border border-[var(--text)]/5 hover:border-[var(--primary)]/30 transition-all duration-500 hover:shadow-2xl hover:shadow-[var(--primary)]/10 hover:-translate-y-2`}>
            
            {/* Service Icon */}
            <div class="mb-8 w-16 h-16 rounded-2xl bg-[var(--primary)]/10 text-[var(--primary)] flex items-center justify-center transition-transform duration-500 group-hover:rotate-[15deg]">
              <div class="w-8 h-8" set:html={serviceIcons[index % serviceIcons.length]} />
            </div>

            {/* Service Content */}
            <h3 class="text-[var(--fs-lg)] font-bold text-[var(--text)] mb-4" style="font-family: var(--heading-font);">
              {service.name}
            </h3>
            
            <p class="text-[var(--text-muted)] leading-relaxed mb-8" style="font-size: var(--fs-base);">
              {service.description}
            </p>

            {/* Micro Interaction Arrow */}
            <div class="mt-auto flex items-center gap-2 text-[var(--primary)] font-bold opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-[-10px] group-hover:translate-x-0">
              <span class="text-sm">Learn more</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>

            {/* Decorative Card Background Decoration */}
            <div class="absolute top-0 right-0 p-8 opacity-0 group-hover:opacity-5 transition-opacity duration-700">
               <div class="w-24 h-24 scale-150" set:html={serviceIcons[index % serviceIcons.length]} />
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /* Reveal helper from global.css */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
</style>
