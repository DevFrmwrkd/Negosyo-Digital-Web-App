---
/**
 * ServicesD - Stats Grid with Quote
 * Light (#fafafa) background. Badge with dot + "SERVICES" text.
 * Large description text with last words italic. Stats row. Full-width grayscale image.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'What We Do',
  subheadline = '',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.servicesBadge !== false;
const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showImage = visibility?.servicesImage !== false;
const showList = visibility?.servicesList !== false;

// Auto-generate stats from services
const serviceCount = services.length;
const stats = [
  { value: `${serviceCount}+`, label: 'Services Offered' },
  { value: '100%', label: 'Client Satisfaction' },
  { value: '10+', label: 'Years Experience' },
];

// Word-reveal: make last 2 words italic
function formatSubheadline(text: string): { normal: string; italic: string } {
  const words = text.trim().split(/\s+/);
  if (words.length <= 2) {
    return { normal: '', italic: text.trim() };
  }
  const italic = words.slice(-2).join(' ');
  const normal = words.slice(0, -2).join(' ');
  return { normal, italic };
}

const formattedSub = subheadline ? formatSubheadline(subheadline) : null;
---

<section id="services" class="reveal bg-[var(--bg)] py-24 md:py-32 lg:py-48 relative overflow-hidden">
  {/* Modern background element */}
  <div class="absolute top-0 left-0 w-full h-[50%] bg-gradient-to-b from-[var(--primary)]/5 to-transparent pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">

    {/* Badge */}
    {showBadge && (
      <div class="reveal mb-10 flex items-center gap-6">
        <span class="h-4 w-4 rounded-full bg-[var(--primary)] shadow-[0_0_20px_var(--primary)] animate-pulse"></span>
        <span class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)]">
          Provisions
        </span>
      </div>
    )}

    {/* Headline */}
    {showHeadline && (
      <h2
        class="reveal-delay-1 reveal mb-10 max-w-5xl font-black leading-[1.05] tracking-tighter text-[var(--text)]"
        style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);"
      >
        {headline}
      </h2>
    )}

    {/* Subheadline - large text with last words italic */}
    {showSubheadline && formattedSub && (
      <p
        class="reveal-delay-2 reveal mb-20 max-w-5xl leading-[1.4] text-[var(--text-muted)] font-medium md:mb-32"
        style="font-size: var(--fs-2xl);"
      >
        {formattedSub.normal}{' '}
        <span class="italic font-light opacity-50 block mt-4 lg:inline lg:mt-0">
          {formattedSub.italic}
        </span>
      </p>
    )}

    {/* Stats Row */}
    {showList && (
      <div class="reveal-delay-3 reveal mb-20 grid grid-cols-1 md:grid-cols-3 gap-12 border-y border-[var(--text)]/10 py-16 md:mb-32 md:gap-20 md:py-24">
        {stats.map((stat) => (
          <div class="text-center group flex flex-col items-center">
            <span
              class="reveal mb-4 block font-black text-[var(--text)] transition-transform duration-700 group-hover:scale-110 group-hover:-translate-y-2"
              style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);"
            >
              {stat.value}
            </span>
            <span class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)] opacity-60">
              {stat.label}
            </span>
          </div>
        ))}
      </div>
    )}

    {/* Service list - cards */}
    {showList && (
      <div class="reveal-delay-4 reveal mb-24 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3 md:mb-40">
        {services.map((service, index) => (
          <div 
            class="reveal flex flex-col items-start gap-8 rounded-[3rem] bg-[var(--surface)] p-10 border border-[var(--text)]/5 transition-all duration-700 hover:shadow-[0_40px_80px_rgba(0,0,0,0.1)] hover:-translate-y-3"
            style={`transition-delay: ${index * 0.1}s;`}
          >
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--primary)] text-[var(--text-inverse)] shadow-lg shadow-[var(--primary)]/20 transition-transform duration-500 hover:rotate-[15deg]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-[var(--fs-xl)] font-bold text-[var(--text)] mb-4 tracking-tight" style="font-family: var(--heading-font, inherit);">
                {service.name}
              </h3>
              <p class="text-[var(--fs-base)] leading-relaxed text-[var(--text-muted)] font-medium">
                {service.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    )}

    {/* Full-width image */}
    {showImage && (
      <div class="reveal-delay-5 reveal overflow-hidden rounded-[3rem] lg:rounded-[6rem] shadow-2xl border border-[var(--text)]/5 group">
        {mainPhoto ? (
          <img
            src={mainPhoto}
            alt="Our services"
            class="h-auto w-full object-cover transition-all duration-[2s] grayscale group-hover:grayscale-0 group-hover:scale-105"
            style="aspect-ratio: 21 / 9;"
            loading="lazy"
          />
        ) : (
          <div class="flex w-full items-center justify-center bg-[var(--surface)]" style="aspect-ratio: 21 / 9;">
            <span class="text-[var(--fs-xs)] font-bold uppercase tracking-widest text-[var(--text-muted)] opacity-30">Visual Presence</span>
          </div>
        )}
      </div>
    )}
  </div>
</section>
