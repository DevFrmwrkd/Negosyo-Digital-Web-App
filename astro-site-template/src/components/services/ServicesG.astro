---
/**
 * ServicesG - First-Class Restaurant / Fine Dining Luxury
 * A minimalist experience-focused layout that presents services
 * as an elegant "Curated Selection" with numbered items.
 */
interface Props {
  headline: string;
  subheadline: string;
  services: Array<{ name: string; description: string; icon?: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Services',
  subheadline = 'A Symphony of Flavors',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;
---

<section id="services" class="py-32 bg-[#121212] relative overflow-hidden">
  {/* Dark Layered Background */}
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(197,160,89,0.05)_0%,_transparent_70%)] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-24 max-w-3xl mx-auto">
      {showSubheadline && (
        <span class="reveal inline-block text-[#c5a059] text-xs font-bold tracking-[0.4em] uppercase mb-6 px-4 py-1.5 border border-[#c5a059]/20 rounded-full bg-[#c5a059]/5 backdrop-blur-sm" data-field="services_subheadline" set:html={subheadline}>
        </span>
      )}
      {showHeadline && (
        <h2 class="reveal-delay-1 reveal text-4xl md:text-6xl text-white font-normal mb-8 leading-tight"
            style="font-family: var(--heading-font);"
            data-field="services_headline"
            set:html={headline}>
        </h2>
      )}
      <div class="reveal-delay-2 reveal w-px h-16 bg-gradient-to-b from-[#c5a059] to-transparent mx-auto"></div>
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12">
        {services.map((service, index) => (
          <div class={`reveal reveal-delay-${(index % 3) + 1} group relative p-12 bg-white/5 border border-white/5 backdrop-blur-sm hover:border-[#c5a059]/30 transition-all duration-700 hover:bg-[#c5a059]/5 cursor-default`}>
            
            {/* Number Counter */}
            <div class="absolute top-8 right-8 text-white/5 text-4xl font-bold font-serif opacity-0 transition-opacity duration-700 group-hover:opacity-100 italic" style="font-family: var(--heading-font);">
              0{index + 1}
            </div>

            <div class="mb-10 w-12 h-12 flex items-center justify-center border border-[#c5a059]/30 text-[#c5a059] group-hover:bg-[#c5a059] group-hover:text-black transition-all duration-700">
               <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 21a9 9 0 110-18 9 9 0 010 18zm0 0v-4m0 0a4 4 0 100-8 4 4 0 000 8z" />
               </svg>
            </div>

            <h3 class="text-2xl text-white font-normal mb-6 leading-tight tracking-wide group-hover:text-[#c5a059] transition-colors duration-500"
                style="font-family: var(--heading-font);"
                data-field={`services.${index}.name`}
                set:html={service.name}>
            </h3>

            <p class="text-white/60 text-sm leading-relaxed mb-8 tracking-wide font-light line-clamp-4"
               style="font-family: var(--body-font);"
               data-field={`services.${index}.description`}
               set:html={service.description}>
            </p>

            <div class="flex items-center gap-2 group/btn">
              <span class="text-[10px] font-bold text-[#c5a059] uppercase tracking-[0.2em] transform transition-transform duration-500 group-hover/btn:translate-x-1">Experience Excellence</span>
              <div class="w-8 h-px bg-[#c5a059]/30 transition-all duration-500 group-hover/btn:w-12 group-hover/btn:bg-[#c5a059]"></div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.2s; }
  .reveal-delay-2 { transition-delay: 0.4s; }
  .reveal-delay-3 { transition-delay: 0.6s; }
</style>
