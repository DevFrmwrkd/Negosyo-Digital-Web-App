---
/**
 * ServicesJ - Atelier Mastercraft
 * Minimalist vertical layout with numbered headers,
 * clean typography, and a "What we do best" creative banner.
 */
interface Props {
  headline: string;
  subheadline?: string;
  services: Array<{ name: string; description: string; icon?: string }>;
  visibility?: Record<string, boolean>;
}

const {
  headline = 'What we do best.',
  subheadline = 'DETAILED SERVICES',
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;
---

<section id="services" class="relative py-24 lg:py-48 bg-[var(--bg)] overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12">
    
    {/* Clean Section Header */}
    <div class="flex flex-col lg:flex-row lg:items-end justify-between border-b border-[var(--text)]/10 pb-20 mb-24">
      <div class="max-w-xl">
        {showSubheadline && (
          <div class="reveal mb-12">
            <span class="text-[10px] font-bold text-[var(--text)]/30 tracking-[0.6em] uppercase border-b border-[var(--text)]/10 inline-block pb-1">
              {subheadline}
            </span>
          </div>
        )}
      </div>
      <div>
        {showHeadline && (
          <h2 class="reveal-delay-1 reveal text-[var(--fs-2xl)] font-serif leading-[1] text-[var(--text)] tracking-tighter text-right lg:max-w-lg">
            {headline}
          </h2>
        )}
      </div>
    </div>

    {/* Creative Numbered Grid */}
    {showList && (
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-16 lg:gap-20">
        {services.map((service, i) => (
          <div class="reveal group relative flex flex-col gap-8 transition-transform duration-700 hover:translate-y-[-10px]">
            <div class="flex items-center gap-6">
               <span class="text-[10px] font-bold text-[var(--text)]/20 tracking-wider">
                 {String(i + 1).padStart(2, '0')}
               </span>
               <div class="h-0.5 w-12 bg-[var(--text)]/10 group-hover:w-full group-hover:bg-[var(--text)]/80 transition-all duration-700"></div>
            </div>
            
            <div class="space-y-6">
              <h3 class="text-[var(--fs-lg)] font-serif text-[var(--text)] leading-tight">
                {service.name}
              </h3>
              <p class="text-[10px] lg:text-[12px] text-[var(--text-muted)] leading-relaxed max-w-xs font-medium tracking-tight">
                {service.description}
              </p>
            </div>

            <a href="#contact" class="group/btn inline-flex items-center gap-2 text-[10px] font-bold tracking-[0.4em] uppercase text-[var(--text)] border-b border-[var(--text)]/10 pb-1 mt-auto hover:border-[var(--text)] transition-all">
              LEARN MORE
              <svg class="w-3 h-3 translate-x-0 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
</style>
