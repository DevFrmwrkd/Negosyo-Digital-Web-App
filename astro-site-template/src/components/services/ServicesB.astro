---
/**
 * ServicesB - Minimal Numbered Grid
 * White background. Clean, minimal. Large uppercase serif headline left + numbered service grid right.
 * No images, no badge, no subheadline.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Services',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showHeadline = visibility?.servicesHeadline !== false;
const showList = visibility?.servicesList !== false;

// Limit to max 4 services
const displayServices = services.slice(0, 4);

// Stagger offsets for desktop (in rem)
const staggerOffsets = [0, 2, 0.5, 3];
---

<section id="services" class="reveal bg-white py-16 md:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2 lg:gap-20">

      {/* LEFT - Large headline */}
      {showHeadline && (
        <div class="lg:sticky lg:top-28">
          <h2
            class="font-semibold uppercase leading-[0.95] tracking-[-0.03em] text-[#1a1a1a]"
            style="font-size: clamp(2.5rem, 7vw, 5rem); font-family: var(--heading-font, 'Georgia'), serif; letter-spacing: -0.03em;"
          >
            {headline}
          </h2>
        </div>
      )}

      {/* RIGHT - Numbered grid */}
      {showList && (
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 sm:gap-8">
          {displayServices.map((service, index) => (
            <div
              class="services-b-item"
              style={`--stagger-offset: ${staggerOffsets[index % staggerOffsets.length]}rem;`}
            >
              <span
                class="mb-3 block text-4xl font-bold leading-none text-[var(--primary,#6B8F71)] md:text-5xl"
                style="font-family: var(--heading-font, inherit);"
              >
                {String(index + 1).padStart(2, '0')}
              </span>
              <h3 class="mb-2 text-lg font-bold text-[#1a1a1a]" style="font-family: var(--heading-font, inherit);">
                {service.name}
              </h3>
              <p class="leading-relaxed text-gray-500" style="font-size: clamp(0.875rem, 1.2vw, 1rem);">
                {service.description}
              </p>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Staggered offset on desktop only */
  @media (min-width: 640px) {
    .services-b-item:nth-child(even) {
      padding-top: var(--stagger-offset, 0);
    }
  }
</style>
