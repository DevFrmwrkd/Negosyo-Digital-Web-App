---
/**
 * ServicesB - Minimal Numbered Grid
 * White background. Clean, minimal. Large uppercase serif headline left + numbered service grid right.
 * No images, no badge, no subheadline.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Services',
  services = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showHeadline = visibility?.servicesHeadline !== false;
const showList = visibility?.servicesList !== false;

// Limit to max 4 services
const displayServices = services.slice(0, 4);

// Stagger offsets for desktop (in rem)
const staggerOffsets = [0, 2, 0.5, 3];
---

<section id="services" class="reveal bg-[var(--bg)] py-24 md:py-32 lg:py-48 relative overflow-hidden">
  {/* Modern background element */}
  <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-[var(--primary)]/5 blur-[100px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-start gap-20 lg:grid-cols-2 lg:gap-32">

      {/* LEFT - Large headline */}
      {showHeadline && (
        <div class="reveal lg:sticky lg:top-40 max-w-xl">
          {/* Badge */}
          <div class="mb-8 w-fit rounded-full bg-[var(--primary)]/5 border border-[var(--primary)]/10 px-6 py-2">
            <span class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)]">Capabilities</span>
          </div>
          <h2
            class="font-black uppercase leading-[0.85] tracking-tighter text-[var(--text)]"
            style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);"
          >
            {headline}
          </h2>
          <div class="mt-12 h-1 w-24 bg-[var(--primary)] rounded-full"></div>
        </div>
      )}

      {/* RIGHT - Numbered grid */}
      {showList && (
        <div class="grid grid-cols-1 gap-16 md:grid-cols-2 md:gap-24">
          {displayServices.map((service, index) => (
            <div
              class="reveal services-b-item group relative"
              style={`--stagger-offset: ${staggerOffsets[index % staggerOffsets.length]}rem; transition-delay: ${index * 0.15}s;`}
            >
              <div class="relative z-10">
                <span
                  class="mb-8 block font-black leading-none text-[var(--primary)] opacity-40 transition-all duration-700 group-hover:opacity-100 group-hover:translate-x-4"
                  style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
                <h3 class="mb-6 font-bold text-[var(--text)] tracking-tight group-hover:translate-x-4 transition-all duration-700" 
                    style="font-size: var(--fs-xl); font-family: var(--heading-font, inherit);">
                  {service.name}
                </h3>
                <p class="leading-[1.6] text-[var(--text-muted)] font-medium group-hover:translate-x-4 transition-all duration-700" 
                   style="font-size: var(--fs-base);">
                  {service.description}
                </p>
              </div>
              
              {/* Subtle hover detail */}
              <div class="absolute -top-4 -left-4 -z-0 h-16 w-16 rounded-[2rem] bg-[var(--primary)]/5 opacity-0 transition-opacity duration-700 group-hover:opacity-100"></div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* Staggered offset on desktop only */
  @media (min-width: 768px) {
    .services-b-item:nth-child(even) {
      padding-top: var(--stagger-offset, 0);
    }
  }
</style>
