---
/**
 * ServicesH - Nexus Forge (Grid Cards)
 * Deep dark background. 
 * Triple cards with icons, bold titles, and subtle hover effects.
 * Asymmetric service layout with numbers.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  services: Array<{
    name: string;
    description: string;
    icon?: string;
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "What We Build",
  subheadline = "Systems that scale with your vision.",
  services = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.servicesHeadline !== false;
const showSubheadline = visibility?.servicesSubheadline !== false && !!subheadline;
const showList = visibility?.servicesList !== false;

const serviceIcons: string[] = [
  // AI / Brain
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/><path d="M12 8v4l3 3"/></svg>`,
  // Cloud
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19l-9.5 0a5.5 5.5 0 0 1 0 -11a5.5 5.5 0 0 1 0 11"/><path d="M17.5 19a4.5 4.5 0 0 0 0 -9"/><path d="M11.5 7a4.5 4.5 0 0 0 -4 3"/></svg>`,
  // Transformation / Rocket
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2l-1.3 -1.3a2 2 0 0 0 -2.8 0l-3.2 3.2a2 2 0 0 1 -2.8 0l-3.2 -3.2a2 2 0 0 1 0 -2.8l3.2 -3.2a2 2 0 0 0 0 -2.8l-1.3 -1.3a2 2 0 0 1 0 -2.8l1.3 -1.3a2 2 0 0 1 2.8 0l1.3 1.3a2 2 0 0 0 2.8 0l3.2 -3.2a2 2 0 0 1 2.8 0l3.2 3.2a2 2 0 0 1 0 2.8l-3.2 3.2a2 2 0 0 0 0 2.8l1.3 1.3a2 2 0 0 1 0 2.8l-1.3 1.3a2 2 0 0 1 -2.8 0z"/></svg>`,
];
---

<section id="services" class="relative bg-[var(--bg)] py-24 md:py-32 lg:py-40">
  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col items-center lg:items-end text-center lg:text-right mb-24">
       {showHeadline && (
        <h2 class="reveal mb-6 font-black uppercase leading-[0.85] tracking-[-0.05em] text-white" 
            style="font-size: clamp(3rem, 7vw, 6rem); font-family: var(--heading-font);">
          {headline}
        </h2>
       )}
       {showSubheadline && (
          <p class="reveal-delay-1 reveal max-w-xl text-white/50 font-medium tracking-[0.05em] uppercase text-xs" style="font-family: var(--body-font);">
            {subheadline}
          </p>
       )}
    </div>

    {showList && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch h-full">
        {services.map((service, index) => (
          <div class={`reveal h-full group bg-white/5 border border-white/5 p-12 rounded-[2.5rem] hover:bg-white/10 hover:border-white/10 hover:scale-[1.02] transition-all duration-500 flex flex-col justify-between`}
               style={`transition-delay: ${index * 0.15 + 0.3}s;`}>
            <div>
              <div class="flex items-center justify-between mb-12">
                <div class="w-16 h-16 bg-white/5 flex items-center justify-center rounded-2xl text-[var(--primary)] group-hover:bg-[var(--primary)] group-hover:text-black transition-colors duration-500" 
                     set:html={serviceIcons[index % serviceIcons.length]}></div>
                <span class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20">0{index+1}</span>
              </div>
              <h3 class="text-3xl font-black uppercase tracking-[-0.03em] text-white mb-6 group-hover:text-[var(--primary)] transition-colors duration-500" style="font-family: var(--heading-font);">
                {service.name}
              </h3>
              <p class="text-white/40 leading-relaxed font-medium" style="font-size: var(--fs-base);">
                {service.description}
              </p>
            </div>
            <div class="mt-12 pt-8 border-t border-white/5">
              <a href="#contact" class="inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.3em] text-white/50 group-hover:text-white transition-all transform group-hover:translate-x-2">
                Learn More
                <svg class="w-4 h-4 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                  <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.15s; }
</style>
