---
/**
 * ContactD - Dark Marquee with Photos
 * Dark background (#0a0a0a). "GET IN TOUCH" badge, infinite scroll image marquee
 * using the photos array, contact info grid, social links, and copyright.
 * Ported from the existing "Footer" section's contact portions.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  featuredImage?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  whatsapp,
  messenger,
  description,
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.contactBadge !== false;
const showHeadline = visibility?.contactHeadline !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

// Duplicate photos for seamless infinite loop
const marqueePhotos = photos.length > 0 ? [...photos, ...photos] : [];

// Social SVG icon paths (stroke-based, 18x18, viewBox 0 0 24 24)
const socialIcons: Record<string, string> = {
  instagram: '<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5M12 7a5 5 0 110 10 5 5 0 010-10m0 2a3 3 0 100 6 3 3 0 000-6z"/>',
  facebook: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  tiktok: '<path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>',
  twitter: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube: '<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"/>',
};
---

<section id="contact" class="reveal bg-[var(--bg)] py-20 md:py-28 lg:py-36">

  {/* Badge */}
  {showBadge && (
    <div class="reveal mb-12 text-center">
      <span
        class="inline-block rounded-full px-6 py-2 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] bg-[var(--primary)] text-[var(--text-inverse)] shadow-lg shadow-[var(--primary)]/20"
      >
        Inquiries
      </span>
    </div>
  )}

  {/* Headline */}
  {showHeadline && (
    <h2
      class="reveal-delay-1 reveal mx-auto mb-16 max-w-4xl text-center font-bold leading-tight tracking-tight text-[var(--text)]"
      style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
    >
      {description || `We'd love to hear from you`}
    </h2>
  )}

  {/* Image Marquee / Carousel */}
  {marqueePhotos.length > 0 && (
    <div class="reveal-delay-2 reveal relative mb-20 overflow-hidden">
      {/* Gradient fade edges */}
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-[var(--bg)] to-transparent md:w-32"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-[var(--bg)] to-transparent md:w-32"></div>

      {/* Scrolling track */}
      <div class="animate-carousel flex w-max gap-6">
        {marqueePhotos.map((photo, i) => (
          <div class="h-[150px] w-[150px] shrink-0 overflow-hidden rounded-2xl border border-[var(--text)]/5 shadow-md md:h-[180px] md:w-[180px]">
            <img
              src={photo}
              alt={`Photo ${(i % photos.length) + 1}`}
              class="h-full w-full object-cover transition-transform duration-700 hover:scale-110"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  )}

  {/* Contact Info Grid */}
  {showInfo && (
    <div class="reveal-delay-3 reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3">

        {/* Address */}
        {address && (
          <div class="text-center group p-8 rounded-[2rem] bg-[var(--surface)] border border-[var(--text)]/5 transition-all hover:-translate-y-1 hover:shadow-xl">
            <p class="mb-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--primary)]">Locate</p>
            <p class="text-[var(--fs-base)] leading-relaxed text-[var(--text)] font-medium">{address}</p>
          </div>
        )}

        {/* Email */}
        <div class="text-center group p-8 rounded-[2rem] bg-[var(--surface)] border border-[var(--text)]/5 transition-all hover:-translate-y-1 hover:shadow-xl">
          <p class="mb-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--primary)]">Message</p>
          <a
            href={`mailto:${email}`}
            class="text-[var(--fs-base)] font-bold text-[var(--text)] transition-all hover:text-[var(--primary)]"
          >
            {email}
          </a>
        </div>

        {/* Phone */}
        <div class="text-center group p-8 rounded-[2rem] bg-[var(--surface)] border border-[var(--text)]/5 transition-all hover:-translate-y-1 hover:shadow-xl">
          <p class="mb-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--primary)]">Connect</p>
          <a
            href={`tel:${phone}`}
            class="text-[var(--fs-base)] font-bold text-[var(--text)] transition-all hover:text-[var(--primary)]"
          >
            {phone}
          </a>
        </div>
      </div>
    </div>
  )}

  {/* Social Links */}
  {showSocial && (
    <div class="reveal-delay-4 reveal mt-16 flex items-center justify-center gap-4">
      {socialLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--surface)] border border-[var(--text)]/5 text-[var(--text)] transition-all hover:bg-[var(--primary)] hover:text-[var(--text-inverse)] hover:-translate-y-1 hover:shadow-lg shadow-[var(--primary)]/20"
          aria-label={link.platform}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={socialIcons[link.platform] || ''} />
        </a>
      ))}
    </div>
  )}

  {/* Copyright */}
  <div class="reveal-delay-5 reveal mx-auto mt-20 max-w-7xl border-t border-[var(--text)]/10 px-4 pt-10 text-center sm:px-6 lg:px-8">
    <p class="text-[var(--fs-xs)] font-bold uppercase tracking-wider text-[var(--text-muted)] opacity-50">&copy; {year} {businessName}</p>
  </div>
</section>
