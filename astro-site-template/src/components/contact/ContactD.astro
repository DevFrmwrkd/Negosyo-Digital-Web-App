---
/**
 * ContactD - Dark Marquee with Photos
 * Dark background (#0a0a0a). "GET IN TOUCH" badge, infinite scroll image marquee
 * using the photos array, contact info grid, social links, and copyright.
 * Ported from the existing "Footer" section's contact portions.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  featuredImage?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  whatsapp,
  messenger,
  description,
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.contactBadge !== false;
const showHeadline = visibility?.contactHeadline !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

// Duplicate photos for seamless infinite loop
const marqueePhotos = photos.length > 0 ? [...photos, ...photos] : [];

// Social SVG icon paths (stroke-based, 18x18, viewBox 0 0 24 24)
const socialIcons: Record<string, string> = {
  instagram: '<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5M12 7a5 5 0 110 10 5 5 0 010-10m0 2a3 3 0 100 6 3 3 0 000-6z"/>',
  facebook: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  tiktok: '<path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>',
  twitter: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube: '<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"/>',
};
---

<section id="contact" class="reveal bg-[#0a0a0a] py-20 md:py-28 lg:py-36">

  {/* Badge */}
  {showBadge && (
    <div class="mb-10 text-center">
      <span
        class="inline-block rounded-full px-5 py-2 text-xs font-semibold uppercase tracking-widest text-white"
        style="background-color: var(--primary, #6B8F71);"
      >
        Get In Touch
      </span>
    </div>
  )}

  {/* Headline */}
  {showHeadline && (
    <h2
      class="mx-auto mb-12 max-w-3xl text-center font-semibold leading-tight tracking-[-0.02em] text-white"
      style="font-size: clamp(2rem, 5vw, 3.5rem); font-family: var(--heading-font, inherit);"
    >
      {description || `We'd love to hear from you`}
    </h2>
  )}

  {/* Image Marquee / Carousel */}
  {marqueePhotos.length > 0 && (
    <div class="relative mb-16 overflow-hidden">
      {/* Gradient fade edges */}
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-[#0a0a0a] to-transparent md:w-24"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-[#0a0a0a] to-transparent md:w-24"></div>

      {/* Scrolling track */}
      <div class="animate-carousel flex w-max gap-3">
        {marqueePhotos.map((photo, i) => (
          <div class="h-[120px] w-[120px] shrink-0 overflow-hidden rounded-xl md:h-[150px] md:w-[150px]">
            <img
              src={photo}
              alt={`Photo ${(i % photos.length) + 1}`}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  )}

  {/* Contact Info Grid */}
  {showInfo && (
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">

        {/* Address */}
        {address && (
          <div class="text-center">
            <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-white/40">Address</p>
            <p class="text-sm leading-relaxed text-white/75">{address}</p>
          </div>
        )}

        {/* Email */}
        <div class="text-center">
          <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-white/40">Email</p>
          <a
            href={`mailto:${email}`}
            class="text-sm text-white/75 transition-colors hover:text-white"
          >
            {email}
          </a>
        </div>

        {/* Phone */}
        <div class="text-center">
          <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-white/40">Phone</p>
          <a
            href={`tel:${phone}`}
            class="text-sm text-white/75 transition-colors hover:text-white"
          >
            {phone}
          </a>
        </div>
      </div>
    </div>
  )}

  {/* Social Links */}
  {showSocial && (
    <div class="mt-12 flex items-center justify-center gap-3">
      {socialLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-white/20"
          aria-label={link.platform}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={socialIcons[link.platform] || ''} />
        </a>
      ))}
    </div>
  )}

  {/* Copyright */}
  <div class="mx-auto mt-16 max-w-7xl border-t border-white/10 px-4 pt-8 text-center sm:px-6 lg:px-8">
    <p class="text-xs text-white/35">&copy; {year} {businessName}. All rights reserved.</p>
  </div>
</section>
