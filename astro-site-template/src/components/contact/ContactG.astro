---
/**
 * ContactG (Footer) - First-Class Restaurant / Fine Dining Luxury
 * A prestigious footer that acts as a brand sign-off.
 * Features hierarchical contact info, elegant social icons,
 * and a "Bookings & Inquiries" focus.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  badgeText?: string;
  headline?: string;
  days?: string;
  hours?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description = 'For any inquiries or to explore your vision further, we invite you to contact our professional team.',
  badgeText = 'Reserve Elite',
  headline = 'Experience the Art of Dining',
  days = 'Wednesday — Sunday',
  hours = '18:00 — 23:00',
  socialLinks = [],
  visibility,
} = Astro.props;

const showBadge = visibility?.contactBadge !== false;
const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false;

const year = new Date().getFullYear();
---

<footer id="contact" class="bg-[#050505] pt-32 pb-16 relative overflow-hidden">
  {/* Luxury Decorative Layers */}
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[#c5a059]/30 to-transparent"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_rgba(197,160,89,0.05)_0%,_transparent_60%)] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-6xl mx-auto flex flex-col items-center text-center">
      
      {showBadge && (
        <span class="reveal inline-block px-8 py-2 bg-[#c5a059] text-black text-[10px] font-black tracking-[0.4em] uppercase mb-12 shadow-[0_10px_40px_-10px_rgba(197,160,89,0.5)]" data-field="footer_badge" set:html={badgeText}>
        </span>
      )}

      {showHeadline && (
        <h2 class="reveal-delay-1 reveal text-4xl md:text-7xl text-white font-normal mb-8 leading-tight tracking-tight italic lowercase"
            style="font-family: var(--heading-font);"
            data-field="footer_headline"
            set:html={headline}>
        </h2>
      )}

      {showDescription && (
        <p class="reveal-delay-2 reveal text-white/50 text-lg max-w-2xl mx-auto italic font-light leading-relaxed mb-16"
           style="font-family: var(--body-font);"
           data-field="footer.brand_blurb"
           set:html={description}>
        </p>
      )}

      {/* Structured Contact Grid */}
      {showInfo && (
        <div class="reveal-delay-3 reveal w-full grid grid-cols-1 md:grid-cols-3 gap-12 border-y border-white/5 py-16 mb-16">
          
          {/* Location */}
          <div class="flex flex-col items-center group">
            <div class="w-12 h-12 bg-white/5 border border-white/5 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#c5a059]/10 group-hover:border-[#c5a059]/30 transition-all duration-500">
               <svg class="w-5 h-5 text-[#c5a059]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
               </svg>
            </div>
            <p class="text-[10px] font-bold text-[#c5a059] uppercase tracking-[0.3em] mb-4">Location</p>
            <p class="text-white/80 text-sm font-medium tracking-wide uppercase leading-loose italic max-w-[200px]" style="font-family: var(--body-font);" data-field="contact.address" set:html={address}>
            </p>
          </div>

          {/* Contact Details */}
          <div class="flex flex-col items-center group">
             <div class="w-12 h-12 bg-white/5 border border-white/5 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#c5a059]/10 group-hover:border-[#c5a059]/30 transition-all duration-500">
                <svg class="w-5 h-5 text-[#c5a059]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
             </div>
             <p class="text-[10px] font-bold text-[#c5a059] uppercase tracking-[0.3em] mb-4">Inquiries</p>
             <p class="text-white/80 text-sm font-medium tracking-wide leading-loose group-hover:text-white transition-colors" style="font-family: var(--body-font);" data-field="contact.email" set:html={email}>
             </p>
             <p class="text-white/80 text-sm font-medium tracking-wide leading-loose group-hover:text-white transition-colors" style="font-family: var(--body-font);" data-field="contact.phone" set:html={phone}>
             </p>
          </div>

          {/* Hours/Social */}
          <div class="flex flex-col items-center group">
             <div class="w-12 h-12 bg-white/5 border border-white/5 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#c5a059]/10 group-hover:border-[#c5a059]/30 transition-all duration-500">
                <svg class="w-5 h-5 text-[#c5a059]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 9 9 0 0118 0z" />
                </svg>
             </div>
             <p class="text-[10px] font-bold text-[#c5a059] uppercase tracking-[0.3em] mb-4">Service</p>
             <p class="text-white/80 text-sm font-medium tracking-wide leading-loose italic uppercase" style="font-family: var(--body-font);" data-field="footer_days" set:html={days}>
             </p>
             <p class="text-white/80 text-sm font-medium tracking-wide leading-loose italic uppercase" style="font-family: var(--body-font);" data-field="footer_hours" set:html={hours}>
             </p>
          </div>
        </div>
      )}

      {/* Social Links & Copyright */}
      <div class="reveal-delay-4 reveal w-full flex flex-col md:flex-row items-center justify-between gap-8 pt-8">
        <p class="text-white/20 text-[10px] uppercase tracking-[0.3em] font-medium order-2 md:order-1">
          © {year} {businessName}. All Reserved.
        </p>

        {showSocial && (
          <div class="flex items-center gap-8 order-1 md:order-2">
            {socialLinks.map((link) => (
              <a href={link.url} class="text-white/30 hover:text-[#c5a059] transition-all transform hover:-translate-y-1" target="_blank" rel="noopener noreferrer">
                <span class="text-[10px] font-bold uppercase tracking-[0.2em]">{link.platform}</span>
              </a>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>
</footer>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.2s; }
  .reveal-delay-2 { transition-delay: 0.4s; }
  .reveal-delay-3 { transition-delay: 0.6s; }
  .reveal-delay-4 { transition-delay: 0.8s; }
</style>
