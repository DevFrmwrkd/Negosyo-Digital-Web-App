---
/**
 * ContactJ - Atelier Brand Sign-off
 * Implements a high-contrast dark-mode creative studio footer.
 * Bold editorial typography, structured contact columns, and cinematic branding.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  badgeText?: string;
  headline?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address = '412 NW Couch St. Suite 300, Portland, OR 97209',
  description = 'Shaping brands that move people. Based in Portland, working worldwide.',
  badgeText = 'START A PROJECT',
  headline = 'ATELIER STUDIO',
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.contactHeadline !== false;
const showBadge = visibility?.contactBadge !== false && !!badgeText;
const showDescription = visibility?.contactDescription !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false;

const year = new Date().getFullYear();
---

<footer id="contact" class="bg-[var(--bg)] text-[var(--text)] pt-24 lg:pt-48 pb-12 overflow-hidden border-t border-[var(--text)]/5">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-[2fr_1fr_1fr] gap-20 lg:gap-32 border-b border-[var(--text)]/10 pb-32 mb-12">
      
      {/* Heavy Studio Branding */}
      <div class="space-y-16">
        <div class="reveal">
          <a href="#" class="text-[var(--fs-xl)] lg:text-[var(--fs-2xl)] font-serif tracking-tight text-[var(--text)] mb-8 leading-none italic block">
            {headline}
          </a>
          <p class="text-[var(--fs-base)] text-[var(--text-muted)] leading-relaxed max-w-sm font-medium italic mt-8">
             {description}
          </p>
        </div>
        
        {showBadge && (
          <a href={`mailto:${email}`} class="reveal-delay-1 reveal group inline-flex items-center gap-6 bg-[var(--primary)] border border-[var(--text)]/10 px-12 py-5 text-[var(--inverse-text)] uppercase text-[10px] font-bold tracking-[0.4em] rounded-full hover:bg-[var(--text)] hover:text-[var(--bg)] transition-all">
             {badgeText}
             <svg class="w-4 h-4 translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
             </svg>
          </a>
        )}
      </div>

      {/* Navigation Blocks */}
      <div class="reveal-delay-2 reveal space-y-12">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.6em] text-[var(--text)]/30 border-b border-[var(--text)]/10 pb-2 inline-block">EXPERTISE</h4>
        <ul class="space-y-8">
          {['Work', 'About', 'Services', 'Journal'].map(link => (
            <li><a href="#" class="text-[var(--fs-sm)] text-[var(--text)]/80 hover:text-[var(--text)] transition-colors tracking-tight font-medium uppercase italic">{link}</a></li>
          ))}
        </ul>
      </div>

      <div class="reveal-delay-3 reveal space-y-12">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.6em] text-[var(--text)]/30 border-b border-[var(--text)]/10 pb-2 inline-block">CONTACT</h4>
        <ul class="space-y-10">
          {showInfo && (
             <li class="space-y-4">
               <a href={`mailto:${email}`} class="block text-[var(--fs-sm)] text-[var(--text)] font-bold hover:underline tracking-tight">{email}</a>
               <a href="#" class="block text-[var(--fs-sm)] text-[var(--text)]/50">{phone}</a>
             </li>
          )}
          <li class="text-[12px] text-white/40 leading-relaxed max-w-[200px] border-l border-white/10 pl-6">
             {address}
          </li>
          <li class="flex items-center gap-8 pt-4">
             {['Instagram', 'Dribbble', 'LinkedIn'].map(link => (
               <a href="#" class="text-[10px] font-bold uppercase tracking-widest text-white/30 hover:text-white transition-all">{link}</a>
             ))}
          </li>
        </ul>
      </div>
    </div>

    {/* Copyright & Legal */}
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-8">
      <p class="text-[10px] font-bold text-[var(--text)]/10 uppercase tracking-[0.2em]">
        © {year} {businessName}. All rights reserved.
      </p>
      <div class="flex items-center gap-12">
        {['Privacy Policy', 'Terms of Service'].map(link => (
          <a href="#" class="text-[10px] font-bold text-[var(--text)]/10 uppercase tracking-[0.2em] hover:text-[var(--text)]/40 transition-colors uppercase italic">{link}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
  .reveal-delay-2 { transition-delay: 0.6s; }
  .reveal-delay-3 { transition-delay: 0.9s; }
</style>
