---
/**
 * ContactB - Craft Style (White/Light)
 * White background. Large italic serif headline, contact arrow link, optional featured image,
 * and a 3-column bottom section with navigation, social links, and contact details.
 * Ported from the existing "Footer" section's contact portions.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  featuredImage?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  whatsapp,
  messenger,
  description,
  socialLinks = [],
  featuredImage,
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false && !!description;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

// Capitalize platform name for text display
function capitalize(str: string): string {
  return str.charAt(0).toUpperCase() + str.slice(1);
}

// Navigation links for the footer columns
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Gallery', href: '#gallery' },
  { label: 'Contact', href: '#contact' },
];
---

<section id="contact" class="reveal bg-[var(--bg)] py-24 md:py-32 lg:py-40 relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    {/* Big Headline */}
    {showHeadline && (
      <h2
        class="reveal mb-12 italic leading-tight tracking-tight text-[var(--text)]"
        style="font-size: var(--fs-display); font-family: var(--heading-font, inherit); font-weight: 400;"
      >
        {description || `Let's create something beautiful together`}
      </h2>
    )}

    {/* Contact Link / Button */}
    <a
      href={`mailto:${email}`}
      class="reveal-delay-1 reveal group mb-20 inline-flex items-center gap-6 text-[var(--fs-xl)] font-bold text-[var(--text)] transition-all hover:text-[var(--primary)] hover:translate-x-4"
    >
      Initiate Project
      <span class="inline-block transition-transform duration-500 group-hover:scale-150">
        &rarr;
      </span>
    </a>

    {/* Featured Image */}
    {featuredImage && (
      <div class="reveal-delay-2 reveal mb-24 overflow-hidden rounded-[3rem] lg:rounded-[4rem] shadow-2xl border border-[var(--text)]/5">
        <img
          src={featuredImage}
          alt={businessName}
          class="aspect-[21/9] w-full object-cover transition-transform duration-[1.5s] hover:scale-110"
          loading="lazy"
        />
      </div>
    )}

    {/* Bottom 3-Column Section */}
    <div class="reveal-delay-3 reveal mt-24 border-t border-[var(--text)]/10 pt-16">
      <div class="grid grid-cols-1 gap-16 sm:grid-cols-2 lg:grid-cols-3">

        {/* Column 1: Navigation Links */}
        <div>
          <h4 class="mb-8 text-[var(--fs-xs)] font-bold uppercase tracking-[0.25em] text-[var(--primary)]">
            Explore
          </h4>
          <nav class="flex flex-col gap-4">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="text-[var(--fs-base)] text-[var(--text-muted)] font-medium transition-all hover:text-[var(--text)] hover:translate-x-2"
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>

        {/* Column 2: Social Links (text format) */}
        {showSocial && (
          <div>
            <h4 class="mb-8 text-[var(--fs-xs)] font-bold uppercase tracking-[0.25em] text-[var(--primary)]">
              Follow
            </h4>
            <div class="flex flex-col gap-4">
              {socialLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--fs-base)] text-[var(--text-muted)] font-medium transition-all hover:text-[var(--text)] hover:translate-x-2"
                >
                  {capitalize(link.platform)}
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Column 3: Contact Details */}
        {showInfo && (
          <div>
            <h4 class="mb-8 text-[var(--fs-xs)] font-bold uppercase tracking-[0.25em] text-[var(--primary)]">
              Reach
            </h4>
            <div class="flex flex-col gap-6">
              <a
                href={`mailto:${email}`}
                class="text-[var(--fs-base)] font-bold text-[var(--text)] transition-colors hover:text-[var(--primary)]"
              >
                {email}
              </a>
              <a
                href={`tel:${phone}`}
                class="text-[var(--fs-base)] font-bold text-[var(--text)] transition-colors hover:text-[var(--primary)]"
              >
                {phone}
              </a>
              {address && (
                <p class="text-[var(--fs-sm)] text-[var(--text-muted)] leading-relaxed font-medium">{address}</p>
              )}
            </div>
          </div>
        )}
      </div>

      {/* Copyright */}
      <div class="mt-24 border-t border-[var(--text)]/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-[var(--fs-xs)] font-bold uppercase tracking-widest text-[var(--text-muted)] opacity-50">&copy; {year} {businessName}</p>
        <p class="text-[var(--fs-xs)] font-bold uppercase tracking-widest text-[var(--text-muted)] opacity-30">Designed for distinction</p>
      </div>
    </div>
  </div>
</section>
