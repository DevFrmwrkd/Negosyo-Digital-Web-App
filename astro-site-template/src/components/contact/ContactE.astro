---
/**
 * ContactE - Floating Glass Terminal
 * A futuristic, high-contrast contact section featuring a glassmorphic form,
 * interactive contact tiles, and a sophisticated typography treatment.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  featuredImage?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description = "Let's bring your vision to life.",
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

const showBadge = visibility?.contactBadge !== false;
const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

// Social SVG icons
const socialIcons: Record<string, string> = {
  instagram: '<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5M12 7a5 5 0 110 10 5 5 0 010-10m0 2a3 3 0 100 6 3 3 0 000-6z"/>',
  facebook: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  tiktok: '<path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>',
  twitter: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube: '<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"/>',
};
---

<section id="contact" class="reveal relative py-24 md:py-32 lg:py-48 bg-[var(--bg)] overflow-hidden">
  {/* Abstract Background Decoration */}
  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03]" 
       style="background-image: radial-gradient(var(--text) 1.5px, transparent 1.5px); background-size: 60px 60px; background-attachment: fixed;">
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-24 md:mb-32">
      {showBadge && (
        <div class="reveal mb-10 flex items-center justify-center gap-6">
          <span class="h-4 w-4 rounded-full bg-[var(--primary)] shadow-[0_0_20px_var(--primary)] animate-pulse"></span>
          <span class="text-[var(--fs-xs)] font-black uppercase tracking-[0.4em] text-[var(--primary)]">
            Open Channels
          </span>
        </div>
      )}

      {showHeadline && (
        <h2 class="reveal-delay-1 reveal mx-auto max-w-5xl font-black italic leading-[1.05] tracking-tighter text-[var(--text)] mb-8" 
            style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
          Start a conversation
        </h2>
      )}

      {showDescription && (
        <p class="reveal-delay-2 reveal mx-auto max-w-3xl leading-[1.6] text-[var(--text-muted)] font-medium"
           style="font-size: var(--fs-xl);">
          {description}
        </p>
      )}
    </div>

    {/* Contact Info Grid - Premium Glass Tiles */}
    {showInfo && (
      <div class="reveal-delay-3 reveal grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {/* Office / Address */}
        {address && (
          <div class="group relative flex flex-col items-center text-center p-12 rounded-[3.5rem] bg-[var(--surface)] border border-[var(--text)]/5 shadow-xl transition-all duration-700 hover:-translate-y-4 hover:shadow-[0_40px_80px_rgba(0,0,0,0.1)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="relative z-10 mb-8 flex h-20 w-20 items-center justify-center rounded-[2rem] bg-[var(--primary)] text-[var(--text-inverse)] shadow-2xl shadow-[var(--primary)]/30 transition-transform duration-500 group-hover:rotate-[15deg] group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="relative z-10">
              <h4 class="mb-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)] opacity-50">Headquarters</h4>
              <p class="text-[var(--fs-base)] font-black text-[var(--text)]">{address}</p>
            </div>
          </div>
        )}

        {/* Email */}
        <div class="group relative flex flex-col items-center text-center p-12 rounded-[3.5rem] bg-[var(--surface)] border border-[var(--text)]/5 shadow-xl transition-all duration-700 hover:-translate-y-4 hover:shadow-[0_40px_80px_rgba(0,0,0,0.1)] overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="relative z-10 mb-8 flex h-20 w-20 items-center justify-center rounded-[2rem] bg-[var(--primary)] text-[var(--text-inverse)] shadow-2xl shadow-[var(--primary)]/30 transition-transform duration-500 group-hover:-rotate-[15deg] group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
            </svg>
          </div>
          <div class="relative z-10">
            <h4 class="mb-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)] opacity-50">Electronic Mail</h4>
            <a href={`mailto:${email}`} class="text-[var(--fs-base)] font-black text-[var(--text)] transition-all hover:text-[var(--primary)] underline decoration-[var(--primary)]/20 underline-offset-8">
              {email}
            </a>
          </div>
        </div>

        {/* Phone */}
        <div class="group relative flex flex-col items-center text-center p-12 rounded-[3.5rem] bg-[var(--surface)] border border-[var(--text)]/5 shadow-xl transition-all duration-700 hover:-translate-y-4 hover:shadow-[0_40px_80px_rgba(0,0,0,0.1)] overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          <div class="relative z-10 mb-8 flex h-20 w-20 items-center justify-center rounded-[2rem] bg-[var(--primary)] text-[var(--text-inverse)] shadow-2xl shadow-[var(--primary)]/30 transition-transform duration-500 group-hover:rotate-[15deg] group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
          </div>
          <div class="relative z-10">
            <h4 class="mb-4 text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)] opacity-50">Direct Line</h4>
            <a href={`tel:${phone}`} class="text-[var(--fs-base)] font-black text-[var(--text)] transition-all hover:text-[var(--primary)] underline decoration-[var(--primary)]/20 underline-offset-8">
              {phone}
            </a>
          </div>
        </div>
      </div>
    )}

    {/* Social & Bottom Bar */}
    <div class="reveal-delay-4 reveal mt-24 md:mt-32 pt-16 border-t border-[var(--text)]/10 flex flex-col md:flex-row items-center justify-between gap-12">
      {showSocial && (
        <div class="flex gap-10">
          {socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--surface)] border border-[var(--text)]/5 text-[var(--text)] shadow-sm transition-all duration-500 hover:bg-[var(--primary)] hover:text-[var(--text-inverse)] hover:-translate-y-2 hover:shadow-2xl hover:shadow-[var(--primary)]/30"
              aria-label={link.platform}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={socialIcons[link.platform] || ''} />
            </a>
          ))}
        </div>
      )}

      <div class="text-center md:text-right">
        <p class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] opacity-40 mb-2">
          &copy; {year} {businessName}
        </p>
        <p class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)] opacity-60">
          All systems operational
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }
</style>
