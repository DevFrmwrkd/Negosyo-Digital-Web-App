---
/**
 * ContactH - Nexus Forge (Refined Footer)
 * Simple, minimalist dark footer/contact.
 * Focus on communication channels and brand sign-off.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  badgeText?: string;
  headline?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description = "Building the future of digital innovation.",
  badgeText = "Connect",
  headline = "Nexus Forge",
  socialLinks = [],
  visibility,
} = Astro.props;

const showBadge = visibility?.contactBadge !== false;
const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false && !!description;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && (socialLinks.length > 0 || !!email || !!phone);

const year = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  instagram: '<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5M12 7a5 5 0 110 10 5 5 0 010-10m0 2a3 3 0 100 6 3 3 0 000-6z"/>',
  facebook: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  tiktok: '<path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>',
  twitter: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube: '<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"/>',
};
---

<footer id="contact" class="reveal bg-[#080808] py-24 md:py-32 lg:py-40 relative overflow-hidden border-t border-white/5">
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20">
      
      {/* Brand Sign-off */}
      <div class="lg:col-span-1">
        {showHeadline && (
          <h2 class="text-4xl font-black uppercase tracking-[-0.05em] text-white mb-8" style="font-family: var(--heading-font);">
             {headline}
          </h2>
        )}
        {showDescription && (
          <p class="text-white/40 text-sm font-medium leading-relaxed mb-10">
            {description}
          </p>
        )}
        {address && (
          <p class="text-white/20 text-[10px] font-black uppercase tracking-widest leading-loose">
            {address}
          </p>
        )}
      </div>

      {/* Quick Links / Navigation */}
      <div class="lg:col-span-1">
        <h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 mb-8">Navigation</h4>
        <ul class="space-y-4">
          {['About', 'Services', 'Work', 'Contact'].map(link => (
             <li><a href={`#${link.toLowerCase()}`} class="text-white/50 hover:text-white transition-colors text-sm font-black uppercase tracking-widest">{link}</a></li>
          ))}
        </ul>
      </div>

      {/* Communication */}
      <div class="lg:col-span-1">
         <h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 mb-8">Contact</h4>
         <div class="space-y-4">
            <a href={`mailto:${email}`} class="block text-white/50 hover:text-white transition-colors text-sm font-black uppercase tracking-widest">{email}</a>
            <a href={`tel:${phone}`} class="block text-white/50 hover:text-white transition-colors text-sm font-black uppercase tracking-widest">{phone}</a>
         </div>
      </div>

       {/* Social */}
       <div class="lg:col-span-1">
         <h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 mb-8">Social</h4>
         <div class="flex gap-6">
            {(socialLinks.length > 0 ? socialLinks : [{platform: 'twitter', url: '#'}, {platform: 'linkedin', url: '#'}, {platform: 'instagram', url: '#'}]).map(link => (
               <a href={link.url} class="group">
                  <div class="w-12 h-12 bg-white/5 border border-white/5 rounded-2xl flex items-center justify-center text-white/40 group-hover:bg-[var(--primary)] group-hover:text-black group-hover:border-[var(--primary)] transition-all duration-500 transform group-hover:-translate-y-2">
                     <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={socialIcons[link.platform] || ''} />
                  </div>
               </a>
            ))}
         </div>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-32 pt-16 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10">
       <p class="text-[10px] font-black uppercase tracking-widest text-white/10">
         &copy; {year} {businessName}. All Rights Reserved.
       </p>
       <div class="flex gap-10">
          <a href="#" class="text-[10px] font-black uppercase tracking-widest text-white/10 hover:text-white/40 transition-colors">Privacy Policy</a>
          <a href="#" class="text-[10px] font-black uppercase tracking-widest text-white/10 hover:text-white/40 transition-colors">Terms of Service</a>
       </div>
    </div>
  </div>
</footer>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
