---
/**
 * ContactC - Bold CTA Section
 * Gradient background using primary color. White text on colored bg.
 * Business name, large bold headline, description, inline contact items,
 * CTA button, social links, and copyright.
 * Ported from the existing "Footer" section's contact portions.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  whatsapp?: string;
  messenger?: string;
  description?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  featuredImage?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  whatsapp,
  messenger,
  description,
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showHeadline = visibility?.contactHeadline !== false;
const showDescription = visibility?.contactDescription !== false && !!description;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false && socialLinks.length > 0;

const year = new Date().getFullYear();

// Social SVG icon paths (stroke-based, 18x18, viewBox 0 0 24 24)
const socialIcons: Record<string, string> = {
  instagram: '<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5M12 7a5 5 0 110 10 5 5 0 010-10m0 2a3 3 0 100 6 3 3 0 000-6z"/>',
  facebook: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  tiktok: '<path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>',
  twitter: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube: '<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"/>',
};
---

<section
  id="contact"
  class="reveal relative overflow-hidden py-20 md:py-28 lg:py-36"
  style="background: linear-gradient(135deg, var(--primary, #6B8F71) 0%, color-mix(in srgb, var(--primary, #6B8F71) 70%, #000) 100%);"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">

    {/* Business Name / Logo */}
    <p
      class="mb-6 text-sm font-semibold uppercase tracking-widest text-white/70"
      style="font-family: var(--heading-font, inherit);"
    >
      {businessName}
    </p>

    {/* Headline */}
    {showHeadline && (
      <h2
        class="mx-auto mb-6 max-w-3xl font-bold leading-tight tracking-[-0.02em] text-white"
        style="font-size: clamp(2rem, 5vw, 3.5rem); font-family: var(--heading-font, inherit);"
      >
        Let's Work Together
      </h2>
    )}

    {/* Description */}
    {showDescription && (
      <p
        class="mx-auto mb-10 max-w-2xl leading-relaxed text-white/80"
        style="font-size: clamp(1rem, 1.5vw, 1.125rem);"
      >
        {description}
      </p>
    )}

    {/* Inline Contact Items */}
    {showInfo && (
      <div class="mb-10 flex flex-col items-center justify-center gap-6 sm:flex-row sm:gap-10">
        {/* Phone */}
        <a
          href={`tel:${phone}`}
          class="inline-flex items-center gap-2 text-sm text-white/90 transition-colors hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          {phone}
        </a>

        {/* Email */}
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-2 text-sm text-white/90 transition-colors hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
          </svg>
          {email}
        </a>
      </div>
    )}

    {/* CTA Button */}
    <a
      href={`mailto:${email}`}
      class="mb-12 inline-flex items-center justify-center gap-2 rounded-full bg-white px-8 py-4 text-sm font-semibold transition-all duration-300 hover:scale-105 hover:shadow-lg"
      style="color: var(--primary, #6B8F71);"
    >
      Get Started
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/>
        <path d="m12 5 7 7-7 7"/>
      </svg>
    </a>

    {/* Social Links */}
    {showSocial && (
      <div class="mb-12 flex items-center justify-center gap-3">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-white/20"
            aria-label={link.platform}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={socialIcons[link.platform] || ''} />
          </a>
        ))}
      </div>
    )}

    {/* Copyright + Legal */}
    <div class="border-t border-white/15 pt-8">
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-6">
        <p class="text-xs text-white/50">&copy; {year} {businessName}. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="#" class="text-xs text-white/40 transition-colors hover:text-white/70">Privacy Policy</a>
          <a href="#" class="text-xs text-white/40 transition-colors hover:text-white/70">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</section>
