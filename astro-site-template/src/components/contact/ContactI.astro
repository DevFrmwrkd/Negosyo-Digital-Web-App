---
/**
 * ContactI - Meridian Strategic Concierge
 * High-end dark footer with structured professional communication.
 * Clean, balanced typography with focused branding.
 */
interface Props {
  businessName: string;
  email: string;
  phone: string;
  address?: string;
  description?: string;
  badgeText?: string;
  headline?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  email,
  phone,
  address,
  description = 'Trusted advisors to industry leaders. New York · London · Singapore · Dubai',
  badgeText = 'Get in Touch',
  headline = 'Meridian & Co',
  socialLinks = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.contactHeadline !== false;
const showBadge = visibility?.contactBadge !== false && !!badgeText;
const showDescription = visibility?.contactDescription !== false;
const showInfo = visibility?.contactInfo !== false;
const showSocial = visibility?.contactSocial !== false;

const year = new Date().getFullYear();
---

<footer id="contact" class="bg-[var(--bg)] text-[var(--text)] pt-24 lg:pt-32 pb-12 overflow-hidden border-t border-[var(--text)]/5">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-12 lg:gap-20 border-b border-[var(--text)]/10 pb-24 mb-12">
      
      {/* Branding Block */}
      <div class="space-y-12">
        <div class="flex flex-col gap-6">
          <a href="#" class="text-[var(--fs-lg)] font-serif tracking-tight text-[var(--text)] mb-4">
            {businessName.toUpperCase()} & CO
          </a>
          <p class="text-[var(--fs-sm)] text-[var(--text-muted)] leading-relaxed max-w-sm font-medium">
             {description}
          </p>
        </div>
      </div>

      {/* Navigation Blocks */}
      <div class="space-y-10">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--text)]/30 italic">Company</h4>
        <ul class="space-y-6">
          {['About Us', 'Our Team', 'Careers'].map(link => (
            <li><a href="#" class="text-[var(--fs-sm)] text-[var(--text)]/80 hover:text-[var(--text)] transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <div class="space-y-10">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--text)]/30 italic">Services</h4>
        <ul class="space-y-6">
          {['Strategy', 'Operations', 'Growth'].map(link => (
            <li><a href="#" class="text-[var(--fs-sm)] text-[var(--text)]/80 hover:text-[var(--text)] transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <div class="space-y-10 text-right lg:text-left">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--text)]/30 italic">Connect</h4>
        <ul class="space-y-6">
          {showInfo && (
             <li><a href={`mailto:${email}`} class="text-[var(--fs-sm)] text-[var(--primary)] font-bold hover:underline">{email}</a></li>
          )}
          {['LinkedIn', 'Twitter / X'].map(link => (
            <li><a href="#" class="text-[var(--fs-sm)] text-[var(--text)]/80 hover:text-[var(--text)] transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>
    </div>

    {/* Copyright & Legal */}
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 pt-8">
      <p class="text-[10px] font-bold text-[var(--text)]/20 uppercase tracking-widest">
        © {year} {businessName}. All rights reserved.
      </p>
      <div class="flex items-center gap-12">
        {['Privacy Policy', 'Terms of Service'].map(link => (
          <a href="#" class="text-[10px] font-bold text-[var(--text)]/20 uppercase tracking-widest hover:text-[var(--text)]/60 transition-colors">{link}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
