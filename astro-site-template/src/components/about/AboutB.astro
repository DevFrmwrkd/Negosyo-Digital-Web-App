---
/**
 * AboutB - Minimal Italic
 * White/clean background with minimal design.
 * Left: Large italic serif description text.
 * Right: Small "About us" label with arrow.
 * Bottom left: Auto-cycling image slideshow.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline,
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;

// Use all available photos for the slideshow
const slideshowPhotos = photos.length > 0 ? photos : [];
---

<section id="about" class="reveal relative overflow-hidden bg-[var(--bg)] py-24 md:py-32 lg:py-48">
  {/* Modern background element */}
  <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-[var(--primary)]/5 blur-[100px] pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">

    {/* Top: Description + Label */}
    <div class="reveal grid grid-cols-1 items-start gap-12 md:grid-cols-12 md:gap-20">

      {/* LEFT: Large italic description */}
      {showDescription && (
        <div class="md:col-span-12 lg:col-span-9">
          <p class="reveal leading-[1.2] text-[var(--text)] italic font-black tracking-tighter"
             style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
            {description}
          </p>
        </div>
      )}

      {/* RIGHT: "About us" label */}
      <div class="reveal-delay-1 reveal md:col-span-12 lg:col-span-3 flex lg:justify-end">
        <div class="group flex items-center gap-6 whitespace-nowrap pt-8 lg:pt-12 text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--primary)]">
          <span class="relative">
            Our DNA
            <span class="absolute -bottom-2 left-0 h-0.5 w-full bg-[var(--primary)] origin-left transition-transform duration-500 scale-x-0 group-hover:scale-x-100"></span>
          </span>
          <span class="flex h-12 w-12 items-center justify-center rounded-full border border-[var(--primary)]/20 transition-all duration-500 group-hover:bg-[var(--primary)] group-hover:text-[var(--text-inverse)] group-hover:scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </div>
    </div>

    {/* Bottom left: Image slideshow */}
    {showImages && slideshowPhotos.length > 0 && (
      <div class="reveal-delay-2 reveal mt-24 md:mt-32">
        <div class="about-b-slideshow relative max-w-[450px] overflow-hidden rounded-[3rem] shadow-[0_50px_100px_rgba(0,0,0,0.1)] border border-[var(--text)]/5" data-photos={JSON.stringify(slideshowPhotos)}>
          {slideshowPhotos.map((photo, index) => (
            <img
              src={photo}
              alt={`${businessName} - ${index + 1}`}
              class={`about-b-slide aspect-[4/5] w-full object-cover grayscale-[0.2] hover:grayscale-0 transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'absolute inset-0 opacity-0'}`}
              loading="lazy"
              data-index={index}
            />
          ))}
          {/* Subtle overlay */}
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--secondary)]/40 via-transparent to-transparent opacity-40"></div>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  // Auto-cycling slideshow for AboutB
  function initAboutBSlideshow() {
    const container = document.querySelector('.about-b-slideshow');
    if (!container) return;

    const slides = container.querySelectorAll<HTMLImageElement>('.about-b-slide');
    if (slides.length <= 1) return;

    let currentIndex = 0;

    setInterval(() => {
      const prevIndex = currentIndex;
      currentIndex = (currentIndex + 1) % slides.length;

      slides[prevIndex].classList.remove('opacity-100');
      slides[prevIndex].classList.add('opacity-0');
      slides[currentIndex].classList.remove('opacity-0');
      slides[currentIndex].classList.add('opacity-100');
    }, 4000);
  }

  // Run on page load
  initAboutBSlideshow();
</script>

<style>
  .about-b-slideshow {
    position: relative;
  }

  .about-b-slide {
    transition: opacity 0.7s ease-in-out;
  }

  .about-b-slide:not(:first-child) {
    position: absolute;
    inset: 0;
  }
</style>
