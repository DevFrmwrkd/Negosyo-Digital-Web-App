---
/**
 * AboutA - Gallery Split Layout
 * Light background with scroll-triggered fade-in animations.
 * Top: Split layout (badge + headline left, description right).
 * Bottom: 4-image horizontal gallery with hover scale and staggered reveals.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'About Us',
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.aboutBadge !== false;
const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;

// Take up to 4 photos for the gallery
const galleryPhotos = photos.slice(0, 4);
---

<section id="about" class="relative overflow-hidden bg-[var(--bg,#F6F7F5)] py-20 md:py-28 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    {/* Top: Split layout */}
    <div class="reveal grid grid-cols-1 items-start gap-8 md:grid-cols-2 md:gap-12 lg:gap-20">

      {/* LEFT: Badge + Headline */}
      <div>
        {showBadge && (
          <div class="reveal mb-6">
            <span class="about-badge inline-block rounded-full px-5 py-2 text-xs font-semibold uppercase tracking-[0.1em]">
              About Us
            </span>
          </div>
        )}

        {showHeadline && (
          <h2 class="reveal reveal-delay-1 font-semibold leading-[1.15] tracking-[-0.02em] text-[var(--secondary,#1F2933)]"
              style="font-size: clamp(2rem, 4vw, 3.5rem); font-family: var(--heading-font, inherit);">
            {headline}
          </h2>
        )}
      </div>

      {/* RIGHT: Description */}
      {showDescription && (
        <div class="flex items-start md:pt-4 lg:pt-8">
          <p class="reveal reveal-delay-2 max-w-lg leading-relaxed text-[var(--secondary,#1F2933)]/65"
             style="font-size: clamp(1rem, 1.5vw, 1.125rem);">
            {description}
          </p>
        </div>
      )}
    </div>

    {/* Bottom: 4-image gallery */}
    {showImages && galleryPhotos.length > 0 && (
      <div class="mt-14 md:mt-20 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
        {galleryPhotos.map((photo, index) => (
          <div class={`reveal reveal-delay-${index + 1} overflow-hidden rounded-2xl`}>
            <img
              src={photo}
              alt={`${businessName} - ${index + 1}`}
              class="aspect-[3/4] w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /*
   * Badge colors: --secondary is #ffffff on dark, #1F2933 on light.
   * We need the badge to contrast against --bg in both cases.
   */
  .about-badge {
    background-color: var(--secondary, #1F2933);
    color: var(--bg, #F6F7F5);
  }
</style>
