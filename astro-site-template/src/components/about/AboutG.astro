---
/**
 * AboutG - First-Class Restaurant / Fine Dining Luxury
 * A sophisticated split layout with asymmetric imagery,
 * decorative bronze accents, and elegant storytelling typography.
 */
interface Props {
  businessName: string;
  headline: string;
  tagline: string;
  description: string;
  signatureName?: string;
  signatureRole?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline = 'Our Story',
  tagline = 'Heritage & Passion',
  description,
  signatureName = 'Executive Chef',
  signatureRole = 'Director of Culinary',
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[1] || photos[0] || '';
const secondaryPhoto = photos[2] || photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;
const showTags = visibility?.aboutTags !== false && tags.length > 0;
---

<section id="about" class="py-32 bg-[#fafafa] overflow-hidden relative">
  {/* Luxury Texture Effect */}
  <div class="absolute inset-x-0 top-0 h-[1000px] bg-[radial-gradient(circle_at_10%_20%,_rgba(197,160,89,0.03)_0%,_transparent_40%)] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center">
      
      {/* Visual Content */}
      <div class="lg:col-span-6 relative order-2 lg:order-1">
        {showImages && (
          <div class="flex gap-4 md:gap-8 items-end">
            <div class="w-2/3 reveal overflow-hidden shadow-2xl">
              <img src={mainPhoto} alt={businessName} class="w-full h-[500px] object-cover transition-transform duration-1000 hover:scale-105" />
            </div>
            <div class="w-1/3 reveal-delay-2 reveal overflow-hidden shadow-xl mb-12">
              <img src={secondaryPhoto} alt={businessName} class="w-full h-[350px] object-cover transition-transform duration-1000 hover:scale-105" />
            </div>
            
            {/* Ornate Gold Detail */}
            <div class="absolute -bottom-8 left-1/3 -translate-x-1/2 w-48 h-48 border border-[#c5a059]/20 -z-10 animate-spin-slow"></div>
          </div>
        )}
      </div>

      {/* Narrative Content */}
      <div class="lg:col-span-6 order-1 lg:order-2">
        {showTagline && (
          <div class="reveal mb-6 flex items-center gap-4">
            <span class="w-12 h-px bg-[#c5a059]/50"></span>
            <span class="text-[#c5a059] text-xs font-bold uppercase tracking-[0.4em]" data-field="about_tagline" set:html={tagline}></span>
          </div>
        )}

        {showHeadline && (
          <h2 class="reveal-delay-1 reveal text-4xl md:text-6xl text-gray-900 font-normal leading-tight mb-8"
              style="font-family: var(--heading-font);"
              data-field="about_headline"
              set:html={headline}>
          </h2>
        )}

        {showDescription && (
          <div class="reveal-delay-2 reveal mb-10 space-y-6">
            <p class="text-gray-600 leading-relaxed text-lg font-light italic" style="font-family: var(--body-font);" data-field="about_description" set:html={description}>
            </p>
          </div>
        )}

        {showTags && (
          <div class="reveal-delay-3 reveal grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
            {usps.map((usp, index) => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-[#c5a059]/10 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-[#c5a059]" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-gray-800 text-sm font-medium tracking-tight uppercase" style="font-family: var(--body-font);">{usp}</span>
              </div>
            ))}
          </div>
        )}

        {/* Signature/CEO Name Mockup for Restaurant Style */}
        <div class="reveal-delay-4 reveal mt-12 flex flex-col gap-1 border-t border-gray-100 pt-8">
           <div>
             <p class="text-3xl font-normal italic leading-none text-gray-900" 
                style="font-family: var(--heading-font);" 
                data-field="about_signature_name" 
                set:html={signatureName}></p>
             <p class="text-xs text-[#c5a059] font-bold tracking-[0.3em] uppercase mt-4" 
                data-field="about_signature_role" 
                set:html={signatureRole}></p>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateX(30px);
    transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (min-width: 1024px) {
    .reveal { transform: translateX(50px); }
  }
  .reveal.visible {
    opacity: 1;
    transform: translateX(0);
  }
  .reveal-delay-1 { transition-delay: 0.2s; }
  .reveal-delay-2 { transition-delay: 0.4s; }
  .reveal-delay-3 { transition-delay: 0.6s; }
  .reveal-delay-4 { transition-delay: 0.8s; }
  
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }
</style>
