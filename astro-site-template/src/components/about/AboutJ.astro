---
/**
 * AboutJ - Atelier Crafting Identities
 * Implements a balanced split layout with vertical creative labeling,
 * fine typography, and descriptive side imagery.
 */
interface Props {
  businessName: string;
  description: string;
  headline: string;
  tagline?: string;
  badgeText?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Crafting identities that endure',
  tagline = 'Our Approach',
  badgeText = 'ABOUT / ATELIER',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[1] || photos[0] || '';

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
const showImage = visibility?.aboutImages !== false && !!mainPhoto;
---

<section id="about" class="relative py-24 lg:py-40 bg-[var(--bg)] overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-20 lg:gap-32 items-center">
      
      {/* Content Side */}
      <div class="relative">
        <div class="reveal mb-12">
           <span class="text-[10px] font-bold text-[var(--text)]/30 tracking-[0.4em] uppercase border-b border-[var(--text)]/10 inline-block pb-1">
             {badgeText}
           </span>
        </div>

        {showHeadline && (
          <h2 class="reveal-delay-1 reveal text-[var(--fs-xl)] lg:text-[var(--fs-2xl)] leading-none text-[var(--text)] tracking-tighter mb-10"
              style="font-family: var(--heading-font);">
            {headline}
          </h2>
        )}

        {showDescription && (
          <div class="reveal-delay-2 reveal max-w-lg space-y-8">
            <p class="text-[var(--fs-base)] text-[var(--text)]/80 leading-loose">
              {description}
            </p>
            {tagline && (
              <a href="#services" class="group inline-flex items-center gap-4 text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--text)] border-b border-[var(--text)] pb-1 hover:border-[var(--text)]/30 transition-all">
                {tagline}
                <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
          </div>
        )}
      </div>

      {/* Visual Side */}
      {showImage && (
        <div class="reveal relative h-[500px] lg:h-[700px] lg:mt-[-80px]">
          <div class="w-full h-full rounded-[1rem] overflow-hidden shadow-2xl">
             <img src={mainPhoto} alt={businessName} class="w-full h-full object-cover grayscale-[0.3] hover:grayscale-0 transition-all duration-1000" />
          </div>
          
          {/* Subtle Labeling */}
          <div class="absolute -right-8 bottom-24 z-20 overflow-hidden">
            <span class="text-[var(--text)]/20 text-[10px] font-bold tracking-[0.6em] uppercase vertical-text">
               PROCESS / DEVELOPMENT 
            </span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
  .reveal-delay-2 { transition-delay: 0.6s; }
</style>
