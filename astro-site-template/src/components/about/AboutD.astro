---
/**
 * AboutD - Quote with Logo Carousel
 * Light (#fafafa) background with centered badge, word-by-word reveal description,
 * and infinite scrolling image/logo carousel at the bottom.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline,
  tagline,
  tags = [],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults (all visible unless explicitly false)
const showBadge = visibility?.aboutBadge !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;

// Split description into words for word-by-word reveal
const descriptionWords = description.split(' ');
const totalWords = descriptionWords.length;
// Last 2-3 words get italic lighter style
const italicStartIndex = Math.max(0, totalWords - 3);

// Duplicate photos for seamless infinite scroll
const carouselPhotos = photos.length > 0 ? [...photos, ...photos] : [];
---

<section id="about" class="reveal relative overflow-hidden bg-[var(--bg)] py-32 md:py-48 lg:py-64">
  {/* Modern background element */}
  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03]" 
       style="background-image: radial-gradient(var(--text) 1.5px, transparent 1.5px); background-size: 60px 60px; background-attachment: fixed;">
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">

    {/* Badge: dot + ABOUT US */}
    {showBadge && (
      <div class="reveal mb-16 flex items-center justify-center gap-6 md:mb-24">
        <span class="h-4 w-4 rounded-full bg-[var(--primary)] shadow-[0_0_20px_var(--primary)] animate-pulse"></span>
        <span class="text-[var(--fs-xs)] font-black uppercase tracking-[0.4em] text-[var(--primary)]">
          Evolutionary Journey
        </span>
      </div>
    )}

    {/* Word-by-word description */}
    {showDescription && (
      <div class="reveal mx-auto max-w-6xl text-center">
        <p class="about-d-words leading-[1.1] text-[var(--text)] font-black tracking-tighter"
           style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
          {descriptionWords.map((word, index) => (
            <span
              class={`reveal-word inline-block transition-all duration-700 ${index >= italicStartIndex ? 'italic font-light opacity-30' : 'opacity-10'}`}
              style={`margin-right: 0.35em; transition-delay: ${index * 0.05}s;`}
            >
              {word}
            </span>
          ))}
        </p>
      </div>
    )}

    {/* Infinite image/logo carousel */}
    {showImages && carouselPhotos.length > 0 && (
      <div class="reveal-delay-2 reveal relative mt-32 md:mt-48">
        {/* Fade edges */}
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-[20%] bg-gradient-to-r from-[var(--bg)] via-[var(--bg)]/80 to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-[20%] bg-gradient-to-l from-[var(--bg)] via-[var(--bg)]/80 to-transparent"></div>

        {/* Carousel track */}
        <div class="about-d-carousel overflow-hidden">
          <div class="about-d-track flex items-center gap-12 md:gap-20 py-10">
            {carouselPhotos.map((photo, index) => (
              <div class="flex-shrink-0 group relative cursor-pointer">
                <img
                  src={photo}
                  alt={`${businessName} partner ${(index % photos.length) + 1}`}
                  class="h-32 w-48 rounded-[2rem] object-cover grayscale opacity-40 transition-all duration-700 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110 group-hover:shadow-2xl md:h-40 md:w-64"
                  loading="lazy"
                />
                <div class="absolute inset-0 rounded-[2rem] border-2 border-[var(--primary)]/0 transition-all duration-700 group-hover:border-[var(--primary)]/20 scale-105 opacity-0 group-hover:opacity-100"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  /* Word reveal - active states */
  .reveal-word.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-word.active.italic {
    opacity: 0.5;
  }

  /* Word reveal - initial state */
  .reveal-word {
    transform: translateY(20px);
  }

  /* Infinite carousel animation */
  .about-d-track {
    animation: aboutD-carousel-scroll 40s linear infinite;
    width: max-content;
  }

  @keyframes aboutD-carousel-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Pause carousel on hover */
  .about-d-carousel:hover .about-d-track {
    animation-play-state: paused;
  }
</style>

<script>
  // IntersectionObserver for word-by-word reveal
  function initAboutDWordReveal() {
    const words = document.querySelectorAll('.about-d-words .reveal-word');
    if (words.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Reveal words with staggered delay
            const wordEls = entry.target.querySelectorAll
              ? [entry.target]
              : [];

            entry.target.classList.add('active');
          }
        });
      },
      {
        threshold: 0.5,
        rootMargin: '0px 0px -10% 0px',
      }
    );

    // Observe each word individually for staggered reveal
    words.forEach((word, index) => {
      // Add a small transition delay for cascade effect
      (word as HTMLElement).style.transitionDelay = `${index * 0.04}s`;
      observer.observe(word);
    });
  }

  // Run on page load
  initAboutDWordReveal();
</script>
