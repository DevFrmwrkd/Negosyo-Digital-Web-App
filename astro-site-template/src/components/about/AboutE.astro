---
/**
 * AboutE - Editorial Asymmetric
 * Sophisticated layout with large display typography, overlapping image frames,
 * and semantic tags for a modern storytelling feel.
 */
interface Props {
  businessName: string;
  description: string;
  headline?: string;
  tagline?: string;
  tags?: string[];
  usps?: string[];
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Our Story',
  tagline,
  tags = ['Aesthetics', 'Wellness', 'Beauty'],
  usps = [],
  photos = [],
  visibility,
} = Astro.props;

const showBadge = visibility?.aboutBadge !== false;
const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showImages = visibility?.aboutImages !== false;

const mainImage = photos[0] || '';
const secondaryImage = photos[1] || photos[0];
---

<section id="about" class="relative py-24 lg:py-40 bg-[var(--bg)] overflow-hidden">
  {/* Decorative Type Background */}
  <div class="absolute top-10 right-[-5%] opacity-[0.03] select-none pointer-events-none hidden lg:block">
    <span class="text-[20rem] font-bold leading-none tracking-tighter text-[var(--text)]">ABOUT</span>
  </div>

  <div class="container mx-auto px-6 relative">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      
      {/* Visual Side (7/12 cols) */}
      <div class="lg:col-span-7 relative">
        <div class="grid grid-cols-12 gap-4">
          {/* Large Main Image */}
          <div class="reveal col-span-10 relative z-10 aspect-[4/5] overflow-hidden rounded-[2rem] shadow-2xl">
            <img src={mainImage} alt={businessName} class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105" />
          </div>
          
          {/* Overlapping Secondary Image */}
          <div class="reveal-delay-2 reveal col-span-6 col-start-7 mt-[-40%] relative z-20 aspect-[3/4] overflow-hidden rounded-[1.5rem] border-8 border-[var(--bg)] shadow-2xl">
            <img src={secondaryImage} alt="" class="w-full h-full object-cover" />
          </div>
        </div>

        {/* Experience Badge */}
        <div class="reveal-delay-3 reveal absolute bottom-12 right-0 lg:right-[-40px] z-30 bg-[var(--primary)] text-[var(--text-inverse)] p-8 rounded-3xl shadow-2xl transform rotate-3">
          <p class="text-[var(--fs-2xl)] font-bold leading-none mb-1">10+</p>
          <p class="text-[var(--fs-xs)] uppercase tracking-widest font-semibold opacity-80">Years of Luxury</p>
        </div>
      </div>

      {/* Content Side (5/12 cols) */}
      <div class="lg:col-span-5">
        {showBadge && (
          <div class="reveal mb-8">
            <div class="flex flex-wrap gap-3">
              {tags.map((tag) => (
                <span class="px-4 py-1.5 rounded-full border border-[var(--primary)]/30 text-[var(--primary)] text-[var(--fs-xs)] font-bold uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        {showHeadline && (
          <h2 class="reveal-delay-1 reveal mb-8 font-bold leading-[1.1] text-[var(--text)]"
              style="font-size: var(--fs-2xl); font-family: var(--heading-font);">
            {headline}
          </h2>
        )}

        {showDescription && (
          <div class="reveal-delay-2 reveal">
            <p class="mb-8 text-[var(--text-muted)] leading-relaxed"
               style="font-size: var(--fs-base);">
              {description}
            </p>
            
            {usps.length > 0 && (
              <ul class="space-y-4 mb-10">
                {usps.map((usp) => (
                  <li class="flex items-start gap-4">
                    <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--accent)]/20 text-[var(--accent)] flex items-center justify-center mt-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </span>
                    <span class="text-[var(--text)] font-medium">{usp}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        )}

        <div class="reveal-delay-3 reveal inline-block">
          <a href="#services" class="group flex items-center gap-4 text-[var(--text)] font-bold hover:text-[var(--primary)] transition-colors">
            <span class="text-[var(--fs-lg)]">Discover our craft</span>
            <span class="w-12 h-[2px] bg-[var(--primary)] group-hover:w-20 transition-all duration-300"></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Intersection Observer class from global.css */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.15s; }
  .reveal-delay-2 { transition-delay: 0.3s; }
  .reveal-delay-3 { transition-delay: 0.45s; }
</style>
