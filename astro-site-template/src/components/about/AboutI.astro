---
/**
 * AboutI - Meridian Strategic Results
 * Elegant centered typography with a soft, warm background.
 * High-end editorial feel with refined serif headline and balanced copy.
 */
interface Props {
  businessName: string;
  description: string;
  headline: string;
  tagline?: string;
  badgeText?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  headline = 'Building trust through exceptional results',
  tagline = 'Our Story',
  badgeText = 'Meridian Story',
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.aboutHeadline !== false;
const showDescription = visibility?.aboutDescription !== false;
const showTagline = visibility?.aboutTagline !== false && !!tagline;
---

<section id="about" class="relative py-24 lg:py-32 bg-[var(--bg)] overflow-hidden">
  <div class="container mx-auto px-6 max-w-4xl text-center relative z-10">
    
    {showTagline && (
      <div class="reveal mb-12">
        <span class="px-6 py-2 rounded-full bg-[var(--surface)] border border-[var(--text)]/10 text-[var(--text)] text-[10px] font-bold uppercase tracking-widest">
           {tagline}
        </span>
      </div>
    )}

    {showHeadline && (
      <h2 class="reveal-delay-1 reveal text-[var(--fs-xl)] lg:text-[var(--fs-2xl)] leading-[1.1] text-[var(--text)] mb-12 tracking-tight"
          style="font-family: var(--heading-font);">
        {headline}
      </h2>
    )}

    {showDescription && (
      <div class="reveal-delay-2 reveal max-w-3xl mx-auto border-t border-[var(--text)]/10 pt-12">
        <p class="text-[var(--fs-base)] lg:text-[var(--fs-base)] text-[var(--text-muted)] leading-loose opacity-80">
          {description}
        </p>
      </div>
    )}

    <div class="reveal-delay-3 reveal mt-12 flex justify-center">
       <div class="h-0.5 w-16 bg-[var(--primary)]"></div>
    </div>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
  .reveal-delay-2 { transition-delay: 0.6s; }
  .reveal-delay-3 { transition-delay: 0.9s; }
</style>
