---
/**
 * GalleryH - Nexus Forge (Impact Grid)
 * Deep dark background. 
 * Vertical scrolling wide-screen items with bold titles and overlays.
 * High-contrast, cinematic feel.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = "Featured Work",
  subheadline = "Selected cases of digital excellence.",
  items = [],
  ctaText,
  ctaLink,
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
---

<section id="gallery" class="relative bg-[var(--bg)] py-24 md:py-32 lg:py-40">
  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col items-center lg:items-start text-center lg:text-left mb-24 max-w-4xl">
       {showHeadline && (
        <h2 class="reveal mb-6 font-black uppercase leading-[0.85] tracking-[-0.05em] text-[var(--text)]" 
            style="font-size: clamp(3rem, 7vw, 6rem); font-family: var(--heading-font);">
          {headline}
        </h2>
       )}
       {showSubheadline && (
          <p class="reveal-delay-1 reveal max-w-xl text-[var(--text-muted)] font-medium tracking-[0.05em] uppercase text-xs" style="font-family: var(--body-font);">
            {subheadline}
          </p>
       )}
    </div>

    {showItems && (
      <div class="space-y-32 h-full">
        {items.map((item, index) => (
          <div class="reveal group relative grid grid-cols-1 md:grid-cols-12 gap-12 items-center h-full">
            <div class={`reveal md:col-span-12 lg:col-span-8 overflow-hidden rounded-[2.5rem] lg:rounded-[4rem] aspect-[16/9] bg-[var(--text)]/5 border border-[var(--text)]/5 shadow-2xl relative order-2 lg:order-1`}>
              {item.image || photos[index] ? (
                <>
                  <img src={item.image || photos[index]} alt={item.title} class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110 grayscale hover:grayscale-0" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
                </>
              ) : (
                <div class="w-full h-full bg-white/5"></div>
              )}
              {/* Case Study Tag */}
              <div class="absolute top-8 left-8">
                <span class="px-5 py-2.5 rounded-full border border-[var(--text)]/10 bg-[var(--surface)]/80 backdrop-blur-md text-[10px] font-black uppercase tracking-[0.3em] text-[var(--text)]/80">Case Study 2024</span>
              </div>
            </div>
            <div class="reveal-delay-2 reveal md:col-span-12 lg:col-span-4 space-y-10 order-1 lg:order-2">
               <div>
                  <h3 class="text-4xl font-black uppercase tracking-[-0.03em] text-[var(--text)] mb-6 group-hover:text-[var(--primary)] transition-colors duration-500" style="font-family: var(--heading-font);">
                    {item.title}
                  </h3>
                  <p class="text-[var(--text-muted)] leading-relaxed font-medium" style="font-size: var(--fs-lg);">
                    {item.description}
                  </p>
               </div>
               <div class="flex flex-wrap gap-4">
                  {item.tags?.map(tag => (
                    <span class="px-5 py-2.5 rounded-2xl border border-[var(--text)]/5 bg-[var(--text)]/5 text-[10px] font-black uppercase tracking-[0.2em] text-[var(--text-muted)]">{tag}</span>
                  ))}
               </div>
               <a href={ctaLink || "#contact"} class="inline-flex items-center gap-6 group/btn w-full justify-between items-center px-10 py-6 border border-[var(--text)]/10 rounded-full text-[var(--text)] font-black uppercase tracking-widest text-xs hover:bg-[var(--text)] hover:text-[var(--bg)] transition-all duration-500">
                  <span>{ctaText || "View Full Project"}</span>
                  <svg class="w-6 h-6 transition-transform group-hover/btn:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
               </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.15s; }
  .reveal-delay-2 { transition-delay: 0.3s; }
</style>
