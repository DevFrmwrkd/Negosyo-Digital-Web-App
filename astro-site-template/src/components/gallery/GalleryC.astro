---
/**
 * GalleryC - Image-Only Grid
 * Light (#fafafa) background. Masonry-style image grid with centered headline and italic accent.
 * Ported from the existing "Featured" section.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Gallery',
  items = [],
  images,
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showImages = visibility?.galleryImages !== false;

// Resolve the image list: images array > photos array > extract from items
const resolvedImages: string[] = (images && images.length > 0)
  ? images
  : (photos && photos.length > 0)
    ? photos
    : items.map((item) => item.image).filter((img): img is string => !!img);

// Split headline for italic accent:
// If headline contains " / ", split on that; otherwise italicize last 2 words
function splitHeadline(text: string): { normal: string; italic: string } {
  if (text.includes(' / ')) {
    const parts = text.split(' / ');
    return { normal: parts[0], italic: parts.slice(1).join(' / ') };
  }
  const words = text.split(' ');
  if (words.length <= 2) {
    return { normal: '', italic: text };
  }
  return {
    normal: words.slice(0, -2).join(' '),
    italic: words.slice(-2).join(' '),
  };
}

const headlineParts = splitHeadline(headline);

// Distribute images across 3 columns for masonry layout
const columns: string[][] = [[], [], []];
resolvedImages.forEach((img, i) => {
  columns[i % 3].push(img);
});
---

<section id="gallery" class="relative bg-[var(--bg)] py-20 md:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-20">
    {/* Header */}
    {showHeadline && (
      <div class="reveal mb-14 text-center md:mb-24">
        <span class="reveal mb-6 inline-block text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--primary)] uppercase">
          Exhibit
        </span>
        <h2
          class="reveal-delay-1 reveal mx-auto max-w-4xl font-bold leading-tight tracking-tight text-[var(--text)]"
          style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
        >
          {headlineParts.normal && (
            <span>{headlineParts.normal}{' '}</span>
          )}
          <em class="not-italic font-bold italic opacity-60">
            {headlineParts.italic}
          </em>
        </h2>
      </div>
    )}

    {/* Masonry Grid */}
    {showImages && resolvedImages.length > 0 && (
      <div class="reveal-delay-2">
        {/* Desktop: 3 columns */}
        <div class="reveal hidden gap-8 md:grid md:grid-cols-3">
          {columns.map((col, colIndex) => (
            <div class="flex flex-col gap-8">
              {col.map((src, imgIndex) => {
                const globalIndex = imgIndex * 3 + colIndex;
                const isTall = globalIndex % 2 === 0;
                return (
                  <div class={`reveal group overflow-hidden rounded-[2.5rem] shadow-xl border border-[var(--text)]/5 ${isTall ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                    <img
                      src={src}
                      alt=""
                      class="h-full w-full object-cover transition-all duration-[1s] group-hover:scale-110 group-hover:shadow-2xl"
                      loading="lazy"
                    />
                  </div>
                );
              })}
            </div>
          ))}
        </div>

        {/* Tablet: 2 columns */}
        <div class="reveal hidden gap-6 sm:grid sm:grid-cols-2 md:hidden">
          {resolvedImages.map((src, i) => {
            const isTall = i % 2 === 0;
            return (
              <div class={`group overflow-hidden rounded-[2.5rem] shadow-lg border border-[var(--text)]/5 ${isTall ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                <img
                  src={src}
                  alt=""
                  class="h-full w-full object-cover transition-all duration-[1s] group-hover:scale-110"
                  loading="lazy"
                />
              </div>
            );
          })}
        </div>

        {/* Mobile: 1 column */}
        <div class="reveal flex flex-col gap-6 sm:hidden">
          {resolvedImages.map((src, i) => {
            const isTall = i % 2 === 0;
            return (
              <div class={`group overflow-hidden rounded-[2.5rem] shadow-lg border border-[var(--text)]/5 ${isTall ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                <img
                  src={src}
                  alt=""
                  class="h-full w-full object-cover transition-all duration-[1s] group-hover:scale-110"
                  loading="lazy"
                />
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>
