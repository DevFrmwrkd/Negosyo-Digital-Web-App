---
/**
 * GalleryG (Featured) - First-Class Restaurant / Fine Dining Luxury
 * A sophisticated featured section designed as "Chef's Recommendations".
 * Large immersive cards with elegant focus on project quality and testimonials.
 */
interface Props {
  headline: string;
  subheadline: string;
  items: Array<{
    title: string;
    description: string;
    image: string;
    tags?: string[];
    testimonial?: { quote: string; author: string; avatar?: string };
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Chef’s Recommendations',
  subheadline = 'Crafted to Perfection',
  items = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
---

<section id="gallery" class="py-32 bg-[#08080c] relative overflow-hidden">
  {/* Luxury Overlay Effect */}
  <div class="absolute inset-x-0 h-px top-0 bg-gradient-to-r from-transparent via-[#c5a059]/20 to-transparent"></div>
  <div class="absolute inset-y-0 w-px left-0 bg-gradient-to-b from-transparent via-[#c5a059]/10 to-transparent"></div>
  <div class="absolute inset-y-0 w-px right-0 bg-gradient-to-b from-transparent via-[#c5a059]/10 to-transparent"></div>

  <div class="container mx-auto px-6 relative z-10 text-center mb-24 max-w-4xl">
    {showSubheadline && (
      <span class="reveal inline-block text-[#c5a059] text-xs font-bold tracking-[0.4em] uppercase mb-8">
        {subheadline}
      </span>
    )}
    {showHeadline && (
      <h2 class="reveal-delay-1 reveal text-4xl md:text-6xl text-white font-normal mb-8 lowercase italic tracking-tight"
          style="font-family: var(--heading-font);">
        {headline}
      </h2>
    )}
    <p class="reveal-delay-2 reveal text-white/50 text-base font-light max-w-2xl mx-auto italic" style="font-family: var(--body-font);">
      A curated collection of our finest creations, where every detail is meticulously considered.
    </p>
  </div>

  {showItems && (
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="space-y-48">
        {items.slice(0, 3).map((item, index) => (
          <div class={`reveal reveal-delay-1 flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center gap-16 lg:gap-32 group`}>
            
            {/* Project Image Panel */}
            <div class="w-full lg:w-1/2 relative">
              <div class="aspect-[4/5] overflow-hidden shadow-[0_40px_100px_-30px_rgba(0,0,0,0.8)] border border-white/5">
                <img src={item.image} alt={item.title} class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-110" />
              </div>
              
              {/* Background Accent Square */}
              <div class={`absolute top-1/2 -translate-y-1/2 ${index % 2 === 0 ? '-left-8 md:-left-16' : '-right-8 md:-right-16'} w-64 h-64 border border-[#c5a059]/10 -z-10 group-hover:bg-[#c5a059]/[0.02] transition-colors duration-1000`}></div>
              
              {/* Image Label/Number Overlay */}
              <div class={`absolute bottom-8 ${index % 2 === 0 ? '-right-12' : '-left-12'} text-[12rem] font-bold text-white/5 leading-none transition-transform duration-700 select-none group-hover:-translate-y-4`}>
                {index + 1}
              </div>
            </div>

            {/* Project Narrative Panel */}
            <div class="w-full lg:w-1/2 space-y-12">
               <div>
                  <div class="flex items-center gap-4 mb-4">
                     <span class="w-8 h-px bg-[#c5a059]/40"></span>
                     <div class="flex gap-4">
                        {item.tags?.map(tag => (
                           <span class="text-[10px] font-bold text-[#c5a059] uppercase tracking-[0.2em]">{tag}</span>
                        ))}
                     </div>
                  </div>
                  <h3 class="text-4xl text-white font-normal mb-8 leading-tight tracking-wide" style="font-family: var(--heading-font);">
                    {item.title}
                  </h3>
                  <p class="text-white/60 text-lg font-light leading-relaxed mb-10 italic" style="font-family: var(--body-font);">
                    {item.description}
                  </p>
               </div>

               {item.testimonial && (
                  <div class="relative pl-12 py-8 bg-[#15151a]/40 border-l-2 border-[#c5a059]/40 backdrop-blur-sm group-hover:bg-[#15151a]/60 transition-colors duration-500">
                    <svg class="absolute top-4 left-4 w-6 h-6 text-[#c5a059]/20" fill="currentColor" viewBox="0 0 24 24">
                       <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.851h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.851h4v10h-10z" />
                    </svg>
                    <p class="text-white/80 font-normal italic leading-relaxed text-base mb-6" style="font-family: var(--body-font);">
                      "{item.testimonial.quote}"
                    </p>
                    <div class="flex items-center gap-4">
                      {item.testimonial.avatar && (
                        <img src={item.testimonial.avatar} alt={item.testimonial.author} class="w-10 h-10 rounded-full border border-white/10" />
                      )}
                      <div>
                        <p class="text-sm font-bold text-white tracking-[0.1em] uppercase">{item.testimonial.author}</p>
                        <p class="text-[10px] text-[#c5a059] font-medium tracking-[0.2em] mt-1 uppercase">Guest Review</p>
                      </div>
                    </div>
                  </div>
               )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {/* Ambient Floating Elements */}
  <div class="absolute top-1/4 -left-32 w-128 h-128 bg-[#c5a059]/5 rounded-full blur-[120px] pointer-events-none -z-10 animate-float-slow"></div>
  <div class="absolute bottom-1/4 -right-32 w-128 h-128 bg-[#c5a059]/5 rounded-full blur-[120px] pointer-events-none -z-10 animate-float-slower"></div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, -60px); }
  }
  .animate-float-slow {
    animation: float 25s ease-in-out infinite;
  }
  .animate-float-slower {
    animation: float 35s ease-in-out infinite reverse;
  }
</style>
