---
/**
 * GalleryJ - Atelier Featured Work
 * Purely cinematic widescreen showcases of single projects,
 * featuring minimal typography and a refined "View all projects" cta.
 */
interface Props {
  headline: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Featured Work',
  subheadline = 'RECENT PROJECTS',
  items = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
---

<section id="gallery" class="relative py-24 lg:py-48 bg-[var(--bg)] overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12">
    
    {/* Creative Header */}
    <div class="flex items-end justify-between border-b border-[var(--text)]/10 pb-12 mb-24">
      <div class="max-w-xl">
        {showSubheadline && (
          <div class="reveal mb-10">
            <span class="text-[10px] font-bold text-[var(--text)]/30 tracking-[0.5em] uppercase border-b border-[var(--text)]/10 inline-block pb-1">
              {subheadline}
            </span>
          </div>
        )}
        {showHeadline && (
          <h2 class="reveal-delay-1 reveal text-[var(--fs-2xl)] font-serif leading-[1] text-[var(--text)] tracking-tighter">
            {headline}
          </h2>
        )}
      </div>
      
      <div class="reveal-delay-2 reveal mb-4">
        <a href="#contact" class="group inline-flex items-center gap-4 text-[10px] font-bold tracking-[0.4em] uppercase text-[var(--text)] border-b border-[var(--text)] pb-1 hover:border-[var(--text)]/30 transition-all">
          VIEW ALL PROJECTS
          <svg class="w-3 h-3 translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

    {/* Immersive Gallery Grid */}
    {showItems && (
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
        {(items.length > 0 ? items : [1, 2]).map((item: any, i) => (
          <div class="reveal group relative flex flex-col gap-10">
            <div class="relative h-[400px] lg:h-[600px] overflow-hidden rounded-[1rem] shadow-2xl border border-[var(--text)]/5 flex flex-col items-center justify-end p-12">
              <img 
                src={item.image || photos[i % photos.length]} 
                alt={item.title} 
                class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-110" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              
              <div class="relative z-10 w-full text-left opacity-0 group-hover:opacity-100 transition-all duration-700 translate-y-8 group-hover:translate-y-0">
                 <div class="flex items-center gap-6 mb-8">
                    <span class="text-[10px] font-black text-white/50 tracking-widest">{String(new Date().getFullYear())}</span>
                    <div class="h-px flex-1 bg-white/20"></div>
                 </div>
                 <h3 class="text-[var(--fs-lg)] font-serif text-white mb-2 leading-tight">
                   {item.title}
                 </h3>
                 <p class="text-[12px] text-white/60 leading-relaxed font-medium">
                   {item.description}
                 </p>
              </div>
            </div>
            
            <div class="flex items-center justify-between border-t border-[var(--text)]/5 pt-8 group-hover:border-[var(--text)]/20 transition-all">
               <h4 class="text-[var(--fs-base)] font-serif text-[var(--text)]">{item.title}</h4>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
  .reveal-delay-2 { transition-delay: 0.6s; }
</style>
