---
/**
 * GalleryE - Immersive Fluid Mosaic
 * A cinematic gallery experience with alternating full-width visual narratives,
 * dynamic text masking, and smooth parallax transitions.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Curated Wonders',
  subheadline = 'Experience the artistry in every project we touch',
  items = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
---

<section id="gallery" class="bg-[var(--bg)] py-32 lg:py-48 relative overflow-hidden">
  {/* Modern background element */}
  <div class="absolute top-0 right-0 w-full h-[50vh] bg-gradient-to-b from-[var(--primary)]/5 to-transparent pointer-events-none"></div>

  <div class="mx-auto max-w-[1500px] px-6 mb-24 lg:mb-40">
    <div class="max-w-5xl">
      {showHeadline && (
        <h2 class="reveal font-black leading-[0.95] tracking-tighter text-[var(--text)] mb-10"
            style="font-size: var(--fs-display); font-family: var(--heading-font);">
          {headline}
        </h2>
      )}
      {showSubheadline && (
        <p class="reveal-delay-1 reveal text-[var(--text-muted)] font-medium max-w-3xl leading-relaxed"
           style="font-size: var(--fs-lg);">
          {subheadline}
        </p>
      )}
    </div>
  </div>

  {showItems && (
    <div class="space-y-40 lg:space-y-64">
      {items.map((item, index) => (
        <div class="reveal group relative">
          <div class="mx-auto max-w-[1500px] px-6">
            <div class="grid lg:grid-cols-12 gap-20 items-center">
              
              {/* Image Narrative */}
              <div class={`lg:col-span-7 relative ${index % 2 === 0 ? '' : 'lg:order-2'}`}>
                <div class="relative aspect-[16/10] overflow-hidden rounded-[3rem] lg:rounded-[5rem] shadow-[0_50px_100px_rgba(0,0,0,0.1)] border border-[var(--text)]/5">
                  <img 
                    src={item.image || photos[index]} 
                    alt={item.title} 
                    class="w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-[2s] group-hover:scale-110" 
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[var(--secondary)]/40 via-transparent to-transparent opacity-40"></div>
                </div>
                
                {/* Floating Index */}
                <div class={`absolute top-[-40px] ${index % 2 === 0 ? 'right-[-20px]' : 'left-[-20px]'} w-28 h-28 rounded-full bg-[var(--surface)] border border-[var(--text)]/10 text-[var(--text)] flex items-center justify-center font-black text-4xl shadow-2xl z-20 transition-all duration-700 group-hover:scale-125 group-hover:bg-[var(--primary)] group-hover:text-[var(--text-inverse)]`}>
                  0{index + 1}
                </div>
              </div>

              {/* Content Narrative */}
              <div class={`lg:col-span-5 ${index % 2 === 0 ? '' : 'lg:order-1'}`}>
                <div class="max-w-xl">
                  {item.tags && (
                    <div class="flex flex-wrap gap-4 mb-10">
                      {item.tags.map(tag => (
                        <span class="px-6 py-2 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] font-bold text-[var(--fs-xs)] uppercase tracking-[0.3em] border border-[var(--primary)]/20 shadow-sm">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  
                  <h3 class="font-black text-[var(--text)] mb-8 leading-[1.1] tracking-tight" 
                      style="font-size: var(--fs-2xl); font-family: var(--heading-font);">
                    {item.title}
                  </h3>
                  
                  <p class="text-[var(--text-muted)] leading-[1.6] mb-14 font-medium" 
                     style="font-size: var(--fs-lg);">
                    {item.description}
                  </p>

                  {item.testimonial && (item.testimonial.quote || item.testimonial.author) && (
                    <div class="relative p-12 rounded-[3rem] bg-[var(--surface)] border border-[var(--text)]/10 shadow-2xl overflow-hidden group/testimonial">
                      <div class="absolute top-0 left-0 w-2 h-full bg-[var(--primary)] shadow-[0_0_20px_var(--primary)] opacity-50 transition-all duration-500 group-hover/testimonial:opacity-100 group-hover/testimonial:w-3"></div>
                      <svg class="absolute top-8 right-8 w-14 h-14 text-[var(--primary)] opacity-[0.08]" fill="currentColor" viewBox="0 0 32 32">
                        <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H8c0-2.2 1.8-4 4-4V8zm14 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-2.2 1.8-4 4-4V8z"/>
                      </svg>
                      <p class="relative z-10 text-[var(--text)] font-semibold italic leading-[1.7] mb-10 text-xl tracking-tight">
                        &ldquo;{item.testimonial.quote}&rdquo;
                      </p>
                      <div class="flex items-center gap-6">
                        <div class="w-14 h-14 rounded-2xl bg-[var(--primary)] text-[var(--text-inverse)] flex items-center justify-center font-black text-lg uppercase shadow-lg shadow-[var(--primary)]/20">
                          {item.testimonial.author[0]}
                        </div>
                        <div>
                          <span class="block font-black text-[var(--text)] text-base tracking-widest uppercase mb-1">{item.testimonial.author}</span>
                          <span class="block text-[var(--fs-xs)] font-bold text-[var(--text-muted)] uppercase tracking-[0.2em] opacity-60">Verified Project</span>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
