---
/**
 * GalleryD - Staggered Masonry Grid
 * Light (#fafafa) background. Badge + headline + optional CTA. 3-column staggered masonry with hover overlays.
 * Ported from the existing "Featured" section.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Portfolio',
  items = [],
  images,
  ctaText,
  ctaLink = '#contact',
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showItems = visibility?.galleryItems !== false;
const showImages = visibility?.galleryImages !== false;

// Resolve images: prefer images array, else extract from items with photos fallback
const resolvedEntries = (images && images.length > 0)
  ? images.map((src, i) => ({
      src,
      title: items[i]?.title || '',
      tags: items[i]?.tags || [],
    }))
  : items.map((item, i) => ({
      src: item.image || photos[i] || '',
      title: item.title,
      tags: item.tags || [],
    }));

// Distribute entries across 3 columns for staggered layout
const columns: Array<typeof resolvedEntries> = [[], [], []];
resolvedEntries.forEach((entry, i) => {
  columns[i % 3].push(entry);
});

// Stagger offsets for each column
const columnOffsets = ['pt-0', 'pt-12 md:pt-20', 'pt-6 md:pt-10'];
---

<section id="gallery" class="relative bg-[var(--bg)] py-20 md:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-20">
    {/* Header */}
    <div class="reveal mb-14 flex flex-col items-start gap-8 md:mb-24 md:flex-row md:items-end md:justify-between">
      <div>
        {/* Badge */}
        <div class="mb-6 flex items-center gap-4">
          <span class="h-3 w-3 rounded-full bg-[var(--primary)] shadow-[0_0_15px_var(--primary)] animate-pulse-dot"></span>
          <span class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.2em] text-[var(--text-muted)]">
            Curation
          </span>
        </div>

        {showHeadline && (
          <h2
            class="max-w-xl font-bold leading-tight tracking-tight text-[var(--text)]"
            style="font-size: var(--fs-2xl); font-family: var(--heading-font, inherit);"
          >
            {headline}
          </h2>
        )}
      </div>

      {/* CTA Button */}
      {ctaText && (
        <a
          href={ctaLink}
          class="inline-flex items-center gap-3 rounded-full bg-[var(--primary)] px-8 py-4 text-[var(--fs-xs)] font-bold uppercase tracking-widest text-[var(--text-inverse)] transition-all duration-500 hover:scale-105 hover:shadow-2xl hover:shadow-[var(--primary)]/30"
        >
          {ctaText}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      )}
    </div>

    {/* Staggered Masonry Grid */}
    {(showItems || showImages) && resolvedEntries.length > 0 && (
      <div class="reveal-delay-2">
        {/* Desktop: 3-column staggered */}
        <div class="reveal hidden gap-8 md:grid md:grid-cols-3 lg:gap-10">
          {columns.map((col, colIndex) => (
            <div class={`flex flex-col gap-8 lg:gap-10 ${columnOffsets[colIndex]}`}>
              {col.map((entry, imgIndex) => {
                const globalIndex = imgIndex * 3 + colIndex;
                const isTall = globalIndex % 3 !== 1;
                return (
                  <div class={`reveal group relative overflow-hidden rounded-[2.5rem] shadow-xl border border-[var(--text)]/5 ${isTall ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                    {entry.src ? (
                      <img
                        src={entry.src}
                        alt={entry.title}
                        class="h-full w-full object-cover transition-transform duration-[1s] group-hover:scale-110"
                        loading="lazy"
                      />
                    ) : (
                      <div class="h-full w-full bg-[var(--surface)]"></div>
                    )}
                    {/* Hover Overlay */}
                    <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-[var(--secondary)]/90 via-[var(--secondary)]/40 to-transparent p-10 opacity-0 transition-all duration-500 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0">
                      {entry.title && (
                        <h3 class="mb-3 font-bold text-[var(--text-inverse)]" style="font-size: var(--fs-lg); font-family: var(--heading-font, inherit);">
                          {entry.title}
                        </h3>
                      )}
                      {entry.tags.length > 0 && (
                        <div class="flex flex-wrap gap-2">
                          {entry.tags.map((tag) => (
                            <span class="text-[var(--fs-xs)] font-bold uppercase tracking-wider text-[var(--text-inverse)]/70">{tag}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          ))}
        </div>

        {/* Tablet: 2 columns */}
        <div class="reveal hidden gap-6 sm:grid sm:grid-cols-2 md:hidden">
          {resolvedEntries.map((entry, i) => {
            const isTall = i % 3 !== 1;
            return (
              <div class={`group relative overflow-hidden rounded-[2rem] shadow-lg border border-[var(--text)]/5 ${isTall ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                {entry.src ? (
                  <img
                    src={entry.src}
                    alt={entry.title}
                    class="h-full w-full object-cover transition-transform duration-[1s] group-hover:scale-110"
                    loading="lazy"
                  />
                ) : (
                  <div class="h-full w-full bg-[var(--surface)]"></div>
                )}
                <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-[var(--secondary)]/90 via-[var(--secondary)]/40 to-transparent p-8 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  {entry.title && (
                    <h3 class="mb-2 font-bold text-[var(--text-inverse)]" style="font-size: var(--fs-base); font-family: var(--heading-font, inherit);">
                      {entry.title}
                    </h3>
                  )}
                  {entry.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {entry.tags.map((tag) => (
                        <span class="text-[var(--fs-xs)] text-[var(--text-inverse)]/70">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>

        {/* Mobile: 1 column */}
        <div class="reveal flex flex-col gap-6 sm:hidden">
          {resolvedEntries.map((entry, i) => {
            const isTall = i % 2 === 0;
            return (
              <div class={`group relative overflow-hidden rounded-[2rem] shadow-lg border border-[var(--text)]/5 ${isTall ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                {entry.src ? (
                  <img
                    src={entry.src}
                    alt={entry.title}
                    class="h-full w-full object-cover transition-transform duration-[1s] group-hover:scale-110"
                    loading="lazy"
                  />
                ) : (
                  <div class="h-full w-full bg-[var(--surface)]"></div>
                )}
                <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-[var(--secondary)]/90 via-[var(--secondary)]/40 to-transparent p-8 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  {entry.title && (
                    <h3 class="mb-2 font-bold text-[var(--text-inverse)]" style="font-size: var(--fs-base); font-family: var(--heading-font, inherit);">
                      {entry.title}
                    </h3>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>
