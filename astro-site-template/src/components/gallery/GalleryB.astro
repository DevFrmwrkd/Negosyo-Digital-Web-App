---
/**
 * GalleryB - Portfolio Stack
 * White background. Left column with headline + clickable numbered list, right column with large image display.
 * Ported from the existing "Featured" section.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Work',
  subheadline = 'Selected projects from our portfolio',
  items = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;

// Build image list with fallback to photos
const itemImages = items.map((item, i) => item.image || photos[i] || '');
const totalItems = items.length;
---

<section id="gallery" class="relative bg-white py-20 md:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-20">
    {/* Mobile: image on top */}
    <div class="reveal mb-10 md:hidden">
      <div class="relative overflow-hidden rounded-xl" data-gallery-b-image-mobile>
        {itemImages.map((src, i) => (
          <img
            src={src}
            alt={items[i]?.title || ''}
            class={`aspect-[3/4] w-full object-cover transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'absolute inset-0 opacity-0'}`}
            data-gallery-b-img-m={i}
            loading="lazy"
          />
        ))}
        {itemImages.length === 0 && (
          <div class="aspect-[3/4] w-full bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl"></div>
        )}
      </div>
    </div>

    <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-[1fr_1.2fr] md:gap-16 lg:gap-24">
      {/* Left Column: headline + numbered list */}
      <div class="reveal">
        {showHeadline && (
          <h2
            class="mb-3 font-semibold leading-tight tracking-[-0.02em] text-[#1F2933]"
            style="font-size: clamp(2rem, 4vw, 3rem); font-family: var(--heading-font, inherit);"
          >
            {headline}
          </h2>
        )}
        {showSubheadline && (
          <p class="mb-10 max-w-md text-sm leading-relaxed text-[#1F2933]/60">
            {subheadline}
          </p>
        )}

        {/* Counter */}
        {showItems && totalItems > 0 && (
          <div class="mb-8 text-xs font-medium tracking-widest text-[#1F2933]/40" data-gallery-b-counter>
            <span data-gallery-b-current>01</span> / <span>{String(totalItems).padStart(2, '0')}</span>
          </div>
        )}

        {/* Numbered List */}
        {showItems && (
          <div class="space-y-1" data-gallery-b-list>
            {items.map((item, i) => (
              <button
                type="button"
                class={`group flex w-full items-center gap-4 rounded-lg px-4 py-3 text-left transition-all duration-300 ${
                  i === 0
                    ? 'bg-[var(--primary,#6B8F71)]/8 text-[var(--primary,#6B8F71)]'
                    : 'text-[#1F2933]/50 hover:bg-[#1F2933]/4 hover:text-[#1F2933]/80'
                }`}
                data-gallery-b-btn={i}
              >
                <span class="text-xs font-medium tabular-nums opacity-60">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span
                  class={`text-sm transition-all duration-300 ${i === 0 ? 'font-semibold' : 'font-normal'}`}
                  style="font-family: var(--heading-font, inherit);"
                >
                  {item.title}
                </span>
              </button>
            ))}
          </div>
        )}
      </div>

      {/* Right Column: Large image display (desktop) */}
      <div class="reveal hidden md:block">
        <div class="relative overflow-hidden rounded-xl" data-gallery-b-image-desktop>
          {itemImages.map((src, i) => (
            <img
              src={src}
              alt={items[i]?.title || ''}
              class={`aspect-[3/4] w-full rounded-xl object-cover transition-opacity duration-500 ${
                i === 0 ? 'opacity-100' : 'absolute inset-0 opacity-0'
              }`}
              data-gallery-b-img-d={i}
              loading="lazy"
            />
          ))}
          {itemImages.length === 0 && (
            <div class="aspect-[3/4] w-full rounded-xl bg-gradient-to-br from-gray-100 to-gray-200"></div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initGalleryB() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-gallery-b-btn]');
    const counterEl = document.querySelector<HTMLSpanElement>('[data-gallery-b-current]');
    const desktopImgs = document.querySelectorAll<HTMLImageElement>('[data-gallery-b-img-d]');
    const mobileImgs = document.querySelectorAll<HTMLImageElement>('[data-gallery-b-img-m]');

    if (!buttons.length) return;

    let activeIndex = 0;

    function setActive(index: number) {
      if (index === activeIndex) return;

      // Update buttons
      buttons.forEach((btn, i) => {
        if (i === index) {
          btn.className = btn.className
            .replace(/text-\[#1F2933\]\/50/g, '')
            .replace(/hover:bg-\[#1F2933\]\/4/g, '')
            .replace(/hover:text-\[#1F2933\]\/80/g, '');
          btn.classList.add('bg-[var(--primary,#6B8F71)]/8', 'text-[var(--primary,#6B8F71)]');
          const nameSpan = btn.querySelector('span:last-child');
          if (nameSpan) nameSpan.classList.replace('font-normal', 'font-semibold');
        } else {
          btn.classList.remove('bg-[var(--primary,#6B8F71)]/8', 'text-[var(--primary,#6B8F71)]');
          btn.classList.add('text-[#1F2933]/50');
          const nameSpan = btn.querySelector('span:last-child');
          if (nameSpan) nameSpan.classList.replace('font-semibold', 'font-normal');
        }
      });

      // Update images
      desktopImgs.forEach((img, i) => {
        if (i === index) {
          img.classList.replace('opacity-0', 'opacity-100');
          img.classList.remove('absolute', 'inset-0');
        } else {
          img.classList.replace('opacity-100', 'opacity-0');
          if (!img.classList.contains('absolute')) {
            img.classList.add('absolute', 'inset-0');
          }
        }
      });

      mobileImgs.forEach((img, i) => {
        if (i === index) {
          img.classList.replace('opacity-0', 'opacity-100');
          img.classList.remove('absolute', 'inset-0');
        } else {
          img.classList.replace('opacity-100', 'opacity-0');
          if (!img.classList.contains('absolute')) {
            img.classList.add('absolute', 'inset-0');
          }
        }
      });

      // Update counter
      if (counterEl) {
        counterEl.textContent = String(index + 1).padStart(2, '0');
      }

      activeIndex = index;
    }

    buttons.forEach((btn) => {
      const index = parseInt(btn.getAttribute('data-gallery-b-btn') || '0', 10);
      btn.addEventListener('click', () => setActive(index));
    });
  }

  // Run on DOMContentLoaded and after Astro page transitions
  document.addEventListener('DOMContentLoaded', initGalleryB);
  document.addEventListener('astro:page-load', initGalleryB);
</script>
