---
/**
 * GalleryA - Scroll Reveal Cards with Testimonials
 * Light (#F6F7F5) background. Full-height alternating project cards with testimonial blocks.
 * Ported from the existing "Featured" section.
 */
interface Props {
  headline?: string;
  subheadline?: string;
  items: Array<{
    title: string;
    description: string;
    image?: string;
    tags?: string[];
    testimonial?: {
      quote: string;
      author: string;
      avatar?: string;
    };
  }>;
  images?: string[];
  ctaText?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Our Work',
  subheadline = 'A showcase of projects we are proud of',
  items = [],
  photos = [],
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
---

<section id="gallery" class="relative bg-[#F6F7F5]">
  {/* Header */}
  {(showHeadline || showSubheadline) && (
    <div class="reveal mx-auto max-w-4xl px-6 pt-24 pb-12 text-center md:pt-32 md:pb-16">
      {showHeadline && (
        <h2
          class="mb-4 font-semibold leading-tight tracking-[-0.02em] text-[#1F2933]"
          style="font-size: clamp(2rem, 5vw, 3.5rem); font-family: var(--heading-font, inherit);"
        >
          {headline}
        </h2>
      )}
      {showSubheadline && (
        <p
          class="mx-auto max-w-2xl leading-relaxed text-[#1F2933]/60"
          style="font-size: clamp(1rem, 1.5vw, 1.125rem);"
        >
          {subheadline}
        </p>
      )}
    </div>
  )}

  {/* Project Cards */}
  {showItems && items.map((item, index) => {
    const isOdd = index % 2 === 0;
    const cardBg = isOdd ? 'bg-white' : 'bg-[#1F2933]';
    const textColor = isOdd ? 'text-[#1F2933]' : 'text-white';
    const descColor = isOdd ? 'text-[#1F2933]/70' : 'text-white/70';
    const tagBg = isOdd ? 'bg-[#1F2933]/8' : 'bg-white/12';
    const tagText = isOdd ? 'text-[#1F2933]/70' : 'text-white/80';
    const borderColor = isOdd ? 'border-[#1F2933]/10' : 'border-white/15';
    const accentColor = isOdd ? 'text-[var(--primary,#6B8F71)]' : 'text-[var(--accent,#4ECDC4)]';
    const imgSrc = item.image || photos[index] || '';

    return (
      <div class={`reveal ${cardBg} py-16 md:py-24`}>
        <div class={`mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 px-6 md:grid-cols-2 md:gap-16 lg:px-20 ${isOdd ? '' : 'direction-rtl'}`}>
          {/* Image */}
          <div class={`${isOdd ? 'md:order-1' : 'md:order-2'}`}>
            {imgSrc ? (
              <img
                src={imgSrc}
                alt={item.title}
                class="aspect-[4/3] w-full rounded-2xl object-cover"
                loading="lazy"
              />
            ) : (
              <div class="aspect-[4/3] w-full rounded-2xl bg-gradient-to-br from-gray-200 to-gray-300"></div>
            )}
          </div>

          {/* Content */}
          <div class={`${isOdd ? 'md:order-2' : 'md:order-1'}`}>
            <h3
              class={`mb-4 font-semibold leading-tight ${textColor}`}
              style="font-size: clamp(1.5rem, 3vw, 2rem); font-family: var(--heading-font, inherit);"
            >
              {item.title}
            </h3>
            <p class={`mb-6 text-sm leading-relaxed ${descColor}`}>
              {item.description}
            </p>

            {/* Tags */}
            {item.tags && item.tags.length > 0 && (
              <div class="mb-8 flex flex-wrap gap-2">
                {item.tags.map((tag) => (
                  <span class={`inline-block rounded-full px-3 py-1 text-xs font-medium ${tagBg} ${tagText}`}>
                    {tag}
                  </span>
                ))}
              </div>
            )}

            {/* Testimonial */}
            {item.testimonial && (
              <div class={`border-t pt-6 ${borderColor}`}>
                <span
                  class={`block text-4xl leading-none ${accentColor}`}
                  style="font-family: Georgia, serif;"
                  aria-hidden="true"
                >
                  &ldquo;
                </span>
                <p class={`mt-2 text-sm italic leading-relaxed ${descColor}`}>
                  {item.testimonial.quote}
                </p>
                <p class={`mt-3 text-sm font-medium ${textColor}`}>
                  {item.testimonial.author}
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    );
  })}
</section>
