---
/**
 * GalleryI - Meridian Portfolio Results
 * Features a minimalist, dark-themed focused CTA and results summary.
 * Designed as a transition point between services and contact.
 */
interface Props {
  headline: string;
  subheadline?: string;
  items: Array<{ title: string; description: string; image?: string; tags?: string[] }>;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  headline = 'Featured Results',
  subheadline = 'Recent Case Studies',
  items = [],
  photos = [],
  ctaText = 'View study',
  ctaLink = '#contact',
  visibility,
} = Astro.props;

const showHeadline = visibility?.galleryHeadline !== false;
const showSubheadline = visibility?.gallerySubheadline !== false && !!subheadline;
const showItems = visibility?.galleryItems !== false;
const showCta = visibility?.galleryCta !== false;
---

<section id="gallery" class="relative py-24 lg:py-48 bg-[var(--bg)] overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12">
    
    {/* Clean Section Header */}
    <div class="flex flex-col lg:flex-row lg:items-end justify-between border-b border-[var(--text)]/10 pb-20 mb-24">
      <div class="max-w-xl">
        {showSubheadline && (
          <div class="reveal mb-12">
            <span class="px-6 py-2 rounded-full bg-[var(--text)]/5 text-[var(--text-muted)] text-[10px] font-bold uppercase tracking-widest border border-[var(--text)]/10">
               {subheadline}
            </span>
          </div>
        )}
        {showHeadline && (
          <h2 class="reveal-delay-1 reveal text-[var(--fs-xl)] lg:text-[var(--fs-2xl)] font-serif leading-[1] text-[var(--text)] tracking-tight">
            {headline}
          </h2>
        )}
      </div>
    </div>

    {/* Creative Results Gallery */}
    {showItems && (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
        {(items.length > 0 ? items : [1, 2, 3]).map((item: any, i) => (
          <div class="reveal group relative flex flex-col gap-10">
            <div class="relative h-[400px] overflow-hidden rounded-[2rem] shadow-2xl border border-[var(--text)]/5">
              <img 
                src={item.image || photos[i % photos.length]} 
                alt={item.title} 
                class="w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-110" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/20 opacity-60"></div>
              
              <div class="absolute bottom-8 left-8 right-8 z-10 transition-transform duration-700 group-hover:-translate-y-4">
                 <div class="flex flex-wrap gap-3 mb-6">
                   {item.tags?.slice(0, 2).map((tag: string) => (
                     <span class="px-4 py-1.5 rounded-full bg-[var(--primary)] text-[var(--inverse-text)] text-[10px] font-bold uppercase tracking-widest">
                       {tag}
                     </span>
                   ))}
                 </div>
                 <h3 class="text-[var(--fs-lg)] font-serif text-[var(--text)] mb-2 leading-tight">
                   {item.title}
                 </h3>
                 <p class="text-[12px] text-[var(--text)]/60 leading-relaxed font-medium">
                   {item.description}
                 </p>
              </div>
            </div>
            
            <a href="#contact" class="group/btn inline-flex items-center gap-4 text-[10px] font-bold uppercase tracking-[0.4em] text-[var(--text)] border-b border-[var(--text)]/10 pb-1 mt-auto hover:border-[var(--text)] transition-all w-fit">
              View study
              <svg class="w-3 h-3 translate-x-0 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    )}
  </div>

  {/* Background Branding Elements */}
  <div class="absolute right-[-100px] top-1/2 -translate-y-1/2 opacity-[0.03] pointer-events-none hidden lg:block">
     <span class="text-[20vw] font-serif text-[var(--text)] tracking-widest leading-none">
       RESULTS
     </span>
  </div>
</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
</style>
