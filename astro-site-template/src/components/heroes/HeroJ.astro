---
/**
 * HeroJ - Atelier Studio Creative 
 * Features a high-contrast immersive image background with heavy,
 * centered overlay typography and a cinematic studio aesthetic.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = 'Crafting brands that move people',
  ctaLabel = 'Explore Our Work',
  ctaLink = '#contact',
  photos = [],
  visibility,
} = Astro.props;

const mainImage = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative h-screen flex items-center justify-center overflow-hidden bg-[var(--bg)]">
  {/* Studio Background */}
  {showImage && (
    <div class="absolute inset-0 z-0">
      <img 
        src={mainImage} 
        alt={businessName} 
        class="w-full h-full object-cover opacity-60 animate-ken-burns scale-110"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)] via-transparent to-[var(--bg)]/40"></div>
    </div>
  )}

  {/* Centered Creative Content */}
  <div class="container mx-auto px-6 relative z-10 text-center max-w-5xl">
    {showTagline && (
      <div class="reveal mb-8">
        <span class="inline-block py-1 text-[var(--text)] text-[10px] font-bold tracking-[0.5em] uppercase border-b border-[var(--text)]/20">
          {badgeText}
        </span>
      </div>
    )}

    {showHeadline && (
      <h1 class="reveal-delay-1 reveal text-[var(--fs-display)] leading-[0.9] text-[var(--text)] tracking-tighter mb-10"
          style="font-family: var(--heading-font);">
        {headline}
      </h1>
    )}

    {showDescription && (
      <p class="reveal-delay-2 reveal text-[var(--fs-lg)] text-[var(--text-muted)] max-w-2xl mx-auto leading-relaxed mb-12 italic font-light">
        {description}
      </p>
    )}

    {showButton && (
      <div class="reveal-delay-3 reveal">
        <a href={ctaLink} 
           class="group relative inline-flex items-center gap-6 border border-[var(--text)]/30 px-12 py-5 text-[var(--text)] uppercase text-[10px] tracking-[0.3em] font-bold overflow-hidden transition-all hover:bg-[var(--text)] hover:text-[var(--bg)]">
           <span class="relative z-10">{ctaLabel}</span>
           <span class="relative z-10 flex h-6 w-6 items-center justify-center rounded-full border border-current transition-transform duration-500 group-hover:rotate-45 group-hover:translate-x-2">
             <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
               <path d="M5 12h14M12 5l7 7-7 7" />
             </svg>
           </span>
        </a>
      </div>
    )}
  </div>

  {/* Creative Sidebar Label */}
  <div class="hidden lg:block absolute left-12 bottom-12 z-20 overflow-hidden">
    <span class="text-[var(--text)]/20 text-[10px] font-bold tracking-[0.8em] uppercase vertical-text">
       STUDIO / EST. 2024
    </span>
  </div>
</section>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }
  @keyframes ken-burns {
    0% { transform: scale(1.1); }
    100% { transform: scale(1.25); }
  }
  .animate-ken-burns {
    animation: ken-burns 30s ease-in-out infinite alternate;
  }
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.3s; }
  .reveal-delay-2 { transition-delay: 0.6s; }
  .reveal-delay-3 { transition-delay: 0.9s; }
</style>
