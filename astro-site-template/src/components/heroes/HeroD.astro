---
/**
 * HeroD - Dark with Services List
 * Full viewport, dark background with image overlay (85% opacity dark gradient).
 * Large italic business name on left, "What we do" numbered description on right.
 * Ported from hero-styles.ts generateHeroStyle4.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  description,
  badgeText,
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

// Visibility defaults
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showHeadline = visibility?.heroHeadline !== false;
const showDescription = visibility?.heroDescription !== false;
const showImage = visibility?.heroImage !== false;

// Split description into sentences for numbered display
const descriptionSentences = description
  ? description.split(/(?<=[.!?])\s+/).filter((s) => s.trim().length > 0)
  : [];
---

<section id="hero" class="relative min-h-screen w-full flex items-center overflow-hidden bg-[var(--bg)]">

  {/* Background Image or Gradient Fallback */}
  {showImage && mainPhoto ? (
    <div class="absolute inset-0 z-[1] overflow-hidden">
      <img src={mainPhoto} alt={businessName} class="h-full w-full object-cover object-center scale-105 animate-slow-zoom" />
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--secondary)] via-[var(--secondary)]/80 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)] via-transparent to-transparent"></div>
    </div>
  ) : (
    <div class="absolute inset-0 z-[1] bg-gradient-to-br from-[var(--secondary)] to-[var(--primary)]"></div>
  )}

  {/* Content Grid */}
  <div class="relative z-[10] mx-auto grid w-full max-w-[1500px] grid-cols-1 gap-20 px-6 pt-40 pb-20 md:gap-32 md:px-16 lg:grid-cols-[1.5fr_1fr] lg:items-center lg:gap-40 lg:px-24">

    {/* Left Column - Badge and Business Name */}
    <div class="flex flex-col gap-10">

      {showTagline && (
        <div class="reveal w-fit flex items-center gap-6 rounded-full border border-[var(--text-inverse)]/20 bg-[var(--text-inverse)]/5 px-8 py-4 backdrop-blur-md">
          <span class="h-3 w-3 rounded-full bg-[var(--primary)] shadow-[0_0_20px_var(--primary)] animate-pulse"></span>
          <span class="text-[var(--fs-xs)] font-black uppercase tracking-[0.4em] text-[var(--primary)]">{badgeText}</span>
        </div>
      )}

      {showHeadline && (
        <h1 class="reveal-delay-1 reveal font-black italic leading-[0.95] tracking-tighter text-[var(--text-inverse)]"
            style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
          {businessName}
        </h1>
      )}
    </div>

    {/* Right Column - What We Do */}
    {showDescription && description && (
      <div class="reveal-delay-2 reveal flex flex-col gap-12 lg:border-l-2 lg:border-[var(--primary)]/30 lg:pl-20">
        <div class="flex items-center gap-6">
          <div class="h-[2px] w-12 bg-[var(--primary)]"></div>
          <span class="text-[var(--fs-xs)] font-black uppercase tracking-[0.4em] text-[var(--primary)]">
            Our Purpose
          </span>
        </div>

        <div class="flex flex-col gap-10">
          {descriptionSentences.length > 0 ? (
            descriptionSentences.map((sentence, i) => (
              <div class="group flex items-start gap-8">
                <span class="shrink-0 pt-2 text-[var(--fs-sm)] font-black text-[var(--primary)] opacity-40 transition-opacity duration-500 group-hover:opacity-100">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <p class="text-[var(--fs-lg)] leading-[1.6] text-[var(--text-inverse)]/80 font-medium transition-all duration-500 group-hover:text-white group-hover:translate-x-2">
                  {sentence.trim()}
                </p>
              </div>
            ))
          ) : (
            <div class="group flex items-start gap-8">
              <span class="shrink-0 pt-2 text-[var(--fs-sm)] font-black text-[var(--primary)]">
                01
              </span>
              <p class="text-[var(--fs-lg)] leading-[1.6] text-[var(--text-inverse)]/80 font-medium group-hover:text-white transition-all duration-500">
                {description}
              </p>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  @keyframes slow-zoom {
    from { transform: scale(1.05); }
    to { transform: scale(1.15); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 25s linear infinite alternate;
  }
</style>
