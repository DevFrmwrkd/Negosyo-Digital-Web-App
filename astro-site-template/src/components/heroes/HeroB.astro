---
/**
 * HeroB - Fullscreen Background
 * Full viewport height, image as background with dark gradient overlay.
 * Headline split into 2 lines in black boxes with fade-up animation.
 * Ported from hero-styles.ts generateHeroStyle2.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

// Visibility defaults
const showHeadline = visibility?.heroHeadline !== false;
const showImage = visibility?.heroImage !== false;

// Split headline into two lines at midpoint of words
const headlineWords = headline.split(' ');
const midPoint = Math.ceil(headlineWords.length / 2);
const topLine = headlineWords.slice(0, midPoint).join(' ');
const bottomLine = headlineWords.slice(midPoint).join(' ');
---

<section id="hero" class="relative min-h-screen w-full overflow-hidden bg-[var(--bg)] flex items-center justify-center">

  {/* Background Image or Gradient Fallback */}
  {showImage && mainPhoto ? (
    <div class="absolute inset-0 z-[1] overflow-hidden">
      <img 
        src={mainPhoto} 
        alt={businessName} 
        class="h-full w-full object-cover object-center scale-105 animate-slow-zoom" 
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--secondary)] via-[var(--secondary)]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--secondary)] via-transparent to-transparent opacity-80"></div>
    </div>
  ) : (
    <div class="absolute inset-0 z-[1] bg-gradient-to-br from-[var(--secondary)] to-[var(--primary)]"></div>
  )}

  {/* Content */}
  <div class="relative z-[10] flex flex-col items-center justify-center px-6 text-center text-[var(--text-inverse)]">

    {/* Business Name - centered at top */}
    <div class="reveal absolute left-1/2 top-12 -translate-x-1/2 text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em] text-[var(--text-inverse)]/50 md:top-16">
      {businessName}
    </div>

    {/* Headline in Color Boxes */}
    {showHeadline && (
      <div class="flex flex-col items-center gap-6 md:gap-8">
        <div class="reveal-delay-1 reveal group relative">
          <span class="inline-block bg-[var(--primary)] px-10 py-5 text-[var(--text-inverse)] uppercase font-black tracking-tighter leading-none md:px-16 md:py-8 lg:px-20 lg:py-10 rounded-[2rem] shadow-2xl skew-x-[-6deg] transition-all duration-500 group-hover:skew-x-0 group-hover:scale-110"
                style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
            {topLine}
          </span>
          <div class="absolute -inset-2 bg-[var(--primary)]/20 blur-2xl rounded-[2rem] -z-10 animate-pulse"></div>
        </div>
        
        {bottomLine && (
          <div class="reveal-delay-2 reveal group relative">
            <span class="inline-block bg-[var(--text-inverse)] px-10 py-5 text-[var(--primary)] uppercase font-black tracking-tighter leading-none md:px-16 md:py-8 lg:px-20 lg:py-10 rounded-[2rem] shadow-2xl skew-x-[6deg] transition-all duration-500 group-hover:skew-x-0 group-hover:scale-110"
                  style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
              {bottomLine}
            </span>
            <div class="absolute -inset-2 bg-white/10 blur-2xl rounded-[2rem] -z-10 animate-pulse"></div>
          </div>
        )}
      </div>
    )}

    {/* Scroll Indicator */}
    <button type="button"
            class="reveal-delay-3 reveal absolute bottom-12 left-1/2 z-[10] flex -translate-x-1/2 flex-col items-center gap-4 border-none bg-transparent p-0 text-[var(--text-inverse)]/80 transition-all duration-500 hover:scale-110 hover:text-white"
            onclick="document.getElementById('about')?.scrollIntoView({ behavior: 'smooth' })">
      <span class="text-[var(--fs-xs)] font-bold uppercase tracking-[0.4em]">Scroll</span>
      <div class="h-16 w-[2px] bg-gradient-to-b from-[var(--text-inverse)] to-transparent rounded-full animate-bounce"></div>
    </button>
  </div>
</section>

<style>
  @keyframes slow-zoom {
    from { transform: scale(1.05); }
    to { transform: scale(1.15); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 20s linear infinite alternate;
  }
</style>
