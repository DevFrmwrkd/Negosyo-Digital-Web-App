---
/**
 * HeroH - Nexus Forge (Refined Minimalist)
 * Deep dark background (#080808) with a cinematic grid overlay.
 * Large bold typography with extreme tracking-tighter.
 * Floating decorative elements and a refined, subtle glassmorphism effect.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText = "Future Ready",
  ctaLabel = "Explore Innovation",
  ctaLink = "#services",
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false;
const showDescription = visibility?.heroDescription !== false;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative min-h-screen flex items-center justify-center bg-[var(--bg)] overflow-hidden py-32">
  {/* Cinematic Grid Overlay */}
  <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" 
       style="background-image: radial-gradient(circle at 2px 2px, var(--text) 1px, transparent 0); background-size: 40px 40px;"></div>
  
  {/* Subtle Ambient Glows */}
  <div class="absolute -top-1/4 -left-1/4 w-1/2 h-1/2 bg-[var(--primary)]/10 rounded-full blur-[160px] animate-pulse-slow"></div>
  <div class="absolute -bottom-1/4 -right-1/4 w-1/2 h-1/2 bg-[var(--accent)]/10 rounded-full blur-[160px] animate-pulse-slow-reverse"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      {/* Content Column */}
      <div class="flex flex-col items-start text-left">
        {showTagline && (
          <div class="reveal mb-10 inline-flex items-center gap-3 px-5 py-2 rounded-full border border-[var(--text)]/10 bg-[var(--text)]/5 backdrop-blur-md">
            <span class="w-2 h-2 rounded-full bg-[var(--primary)] animate-ping"></span>
            <span class="w-2 h-2 rounded-full bg-[var(--primary)] absolute"></span>
            <span class="text-[10px] uppercase tracking-[0.3em] font-black text-[var(--text)]/80">{badgeText}</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="reveal-delay-1 reveal mb-8 font-black uppercase leading-[0.85] tracking-[-0.07em] text-[var(--text)]"
              style="font-size: clamp(3.5rem, 9vw, 8.5rem); font-family: var(--heading-font);">
            {headline.split('<br />').map((line, i) => (
              <>
                {i > 0 && <br />}
                <span class={i % 2 === 1 ? "text-transparent bg-clip-text bg-gradient-to-r from-[var(--primary)] to-[var(--accent)]" : ""}>
                  {line}
                </span>
              </>
            ))}
          </h1>
        )}

        {showDescription && (
          <p class="reveal-delay-2 reveal mb-12 max-w-xl text-[var(--text-muted)] font-medium leading-relaxed"
             style="font-size: var(--fs-lg);">
            {description}
          </p>
        )}

        {showButton && (
          <div class="reveal-delay-3 reveal">
            <a href={ctaLink} 
               class="group relative inline-flex items-center justify-center px-10 py-5 bg-[var(--primary)] text-[var(--inverse-text)] font-black uppercase tracking-widest text-sm rounded-full transition-all duration-500 hover:scale-105 hover:shadow-[0_0_50px_var(--primary-glow)] overflow-hidden">
              <span class="relative z-10 flex items-center gap-3">
                {ctaLabel}
                <svg class="w-5 h-5 transition-transform duration-500 group-hover:translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
              <div class="absolute inset-x-0 bottom-0 h-0 bg-[var(--accent)] transition-all duration-300 group-hover:h-full -z-0"></div>
            </a>
          </div>
        )}
      </div>

      {/* Visual Column */}
      {showImage && (
        <div class="reveal-delay-4 reveal relative hidden lg:block">
          {/* Framed Image */}
          <div class="relative z-10 rounded-[2.5rem] p-3 bg-gradient-to-br from-[var(--text)]/20 to-[var(--text)]/5 backdrop-blur-2xl border border-[var(--text)]/10 shadow-[0_50px_100px_rgba(0,0,0,0.5)] transform -rotate-2 hover:rotate-0 transition-transform duration-700 ease-out glow-border">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="w-full aspect-[4/5] object-cover rounded-2xl grayscale hover:grayscale-0 transition-all duration-1000" />
            ) : (
              <div class="w-full aspect-[4/5] bg-[var(--text)]/5 rounded-2xl flex items-center justify-center">
                <span class="text-[var(--text)]/20 font-black tracking-widest uppercase">Visual Preview</span>
              </div>
            )}
          </div>

          {/* Floating Details */}
          <div class="absolute -bottom-10 -left-12 bg-[var(--surface)] backdrop-blur-2xl border border-[var(--text)]/10 p-6 rounded-3xl shadow-2xl animate-float">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-[var(--primary)]/20 flex items-center justify-center border border-[var(--primary)]/30">
                <svg class="w-6 h-6 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <p class="text-[var(--text-muted)] text-[10px] font-black uppercase tracking-widest">Performance</p>
                <p class="text-[var(--text)] text-xl font-black tabular-nums">99.9% Up</p>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .glow-border {
    position: relative;
  }
  .glow-border::after {
    content: '';
    position: absolute;
    inset: -1px;
    background: linear-gradient(135deg, var(--primary), transparent, var(--accent));
    border-radius: inherit;
    z-index: -1;
    opacity: 0.3;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.1; transform: scale(1); }
    50% { opacity: 0.2; transform: scale(1.1); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 10s ease-in-out infinite;
  }
  .animate-pulse-slow-reverse {
    animation: pulse-slow 12s ease-in-out infinite reverse;
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.15s; }
  .reveal-delay-2 { transition-delay: 0.3s; }
  .reveal-delay-3 { transition-delay: 0.45s; }
  .reveal-delay-4 { transition-delay: 0.6s; }
</style>
