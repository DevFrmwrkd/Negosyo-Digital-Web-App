---
/**
 * HeroC - Centered Carousel
 * Light background (#fafafa) with dot grid pattern, centered content,
 * and infinite scrolling image carousel at bottom.
 * Ported from hero-styles.ts generateHeroStyle3.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  services?: Array<{ name: string; description: string }>;
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  badgeText,
  ctaLabel = 'Book a Call',
  ctaLink = '#contact',
  photos = [],
  visibility,
} = Astro.props;

// Visibility defaults
const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;

// Build carousel images: loop to fill at least 8 slots for seamless scroll
const carouselImages: string[] = [];
if (photos.length > 0) {
  const minImages = 8;
  while (carouselImages.length < minImages) {
    for (const photo of photos) {
      carouselImages.push(photo);
      if (carouselImages.length >= minImages) break;
    }
  }
}

// Split headline to make last part italic
// Look for " in " or " for " to italicize the rest, else last 2 words
let headlinePart1 = headline;
let headlinePart2 = '';

const lowerHeadline = headline.toLowerCase();
let splitIndex = lowerHeadline.lastIndexOf(' in ');
if (splitIndex === -1) {
  splitIndex = lowerHeadline.lastIndexOf(' for ');
}

if (splitIndex !== -1) {
  // Find the actual preposition length (3 for "in", 4 for "for") + leading space
  const preposition = lowerHeadline.charAt(splitIndex + 1) === 'i' ? ' in ' : ' for ';
  headlinePart1 = headline.substring(0, splitIndex + preposition.length);
  headlinePart2 = headline.substring(splitIndex + preposition.length);
} else {
  // Fallback: italicize last 2 words
  const words = headline.split(' ');
  if (words.length > 2) {
    headlinePart1 = words.slice(0, -2).join(' ') + ' ';
    headlinePart2 = words.slice(-2).join(' ');
  }
}
---

<section id="hero" class="relative min-h-screen overflow-hidden pt-32 pb-20 bg-[var(--bg)] flex flex-col justify-between">
  {/* Modern dot grid background */}
  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03]" 
       style="background-image: radial-gradient(var(--text) 1.5px, transparent 1.5px); background-size: 50px 50px; background-attachment: fixed;">
  </div>
  <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-[var(--primary)]/5 to-transparent pointer-events-none"></div>

  {/* Centered Content */}
  <div class="mx-auto max-w-[1300px] px-6 text-center relative z-10 flex-1 flex flex-col items-center justify-center">

    {/* Business Name Badge */}
    <div class="reveal mb-10 w-fit rounded-full border border-[var(--primary)]/20 bg-[var(--primary)]/5 px-8 py-3 shadow-xl backdrop-blur-sm">
      <span class="text-[var(--fs-xs)] font-bold tracking-[0.4em] uppercase text-[var(--primary)]">
        {businessName}
      </span>
    </div>

    {/* Headline with Italic Accent */}
    {showHeadline && (
      <h1 class="reveal-delay-1 reveal mb-10 font-black leading-[1.05] tracking-tighter text-[var(--text)]"
          style="font-size: var(--fs-display); font-family: var(--heading-font, inherit);">
        {headlinePart1}
        {headlinePart2 && (
          <span class="italic font-light opacity-50 block lg:inline-block lg:ml-2">{headlinePart2}</span>
        )}
      </h1>
    )}

    {/* Description */}
    {showTagline && badgeText && (
      <p class="reveal-delay-2 reveal mx-auto mb-14 max-w-[700px] leading-relaxed text-[var(--text-muted)] font-medium"
         style="font-size: var(--fs-lg);">
        {badgeText}
      </p>
    )}

    {/* CTA Button */}
    {showButton && (
      <div class="reveal-delay-3 reveal">
        <a href={ctaLink}
           class="group relative inline-flex items-center justify-center gap-6 rounded-[2rem] bg-[var(--primary)] px-12 py-7 text-[var(--fs-sm)] font-bold uppercase tracking-widest text-[var(--text-inverse)] transition-all duration-500 hover:scale-105 hover:shadow-[0_20px_50px_rgba(var(--primary-rgb),0.5)]">
          {ctaLabel}
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--text-inverse)] text-[var(--primary)] transition-transform duration-500 group-hover:rotate-45">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
    )}
  </div>

  {/* Image Carousel */}
  {showImage && carouselImages.length > 0 && (
    <div class="reveal-delay-4 reveal hero-c-carousel relative mt-20 lg:mt-32 overflow-hidden z-10 w-full">
      {/* Fade edges */}
      <div class="pointer-events-none absolute inset-y-0 left-0 z-[2] w-[20%] bg-gradient-to-r from-[var(--bg)] via-[var(--bg)]/80 to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-[2] w-[20%] bg-gradient-to-l from-[var(--bg)] via-[var(--bg)]/80 to-transparent"></div>

      {/* Carousel Track */}
      <div class="hero-c-track flex w-max gap-10 lg:gap-16 py-16 px-10">
        {carouselImages.map((img, i) => (
          <div class="flex-shrink-0 w-[280px] h-[380px] lg:w-[380px] lg:h-[500px] group relative overflow-hidden rounded-[4rem] shadow-2xl transition-all duration-700 hover:scale-105 hover:-rotate-1">
            <img src={img} alt={`${businessName} - Image ${(i % photos.length) + 1}`} loading="lazy" class="h-full w-full object-cover grayscale-[0.2] transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .hero-c-track {
    animation: heroC-carousel-scroll 60s linear infinite;
  }

  /* Keyframes for infinite scroll - make sure it's half width for seamless loop */
  @keyframes heroC-carousel-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .hero-c-carousel:hover .hero-c-track {
    animation-play-state: paused;
  }
</style>
