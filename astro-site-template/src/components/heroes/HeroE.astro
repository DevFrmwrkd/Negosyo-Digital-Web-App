---
/**
 * HeroE - Glassmorphic Aesthetic
 * A modern, airy hero with a glassmorphic content card and parallax-ready image layout.
 */
interface Props {
  businessName: string;
  headline: string;
  description: string;
  badgeText?: string;
  testimonial?: string;
  ctaLabel?: string;
  ctaLink?: string;
  photos: string[];
  visibility?: Record<string, boolean>;
}

const {
  businessName,
  headline,
  description,
  badgeText,
  testimonial,
  ctaLabel = 'Explore More',
  ctaLink = '#services',
  photos = [],
  visibility,
} = Astro.props;

const mainPhoto = photos[0] || '';
const secondaryPhoto = photos[1] || photos[0];

const showHeadline = visibility?.heroHeadline !== false;
const showTagline = visibility?.heroTagline !== false && !!badgeText;
const showDescription = visibility?.heroDescription !== false;
const showTestimonial = visibility?.heroTestimonial !== false && !!testimonial;
const showButton = visibility?.heroButton !== false;
const showImage = visibility?.heroImage !== false;
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[var(--bg)] py-24 lg:py-32">
  {/* Dynamic Background Elements */}
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-[var(--primary)]/10 blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-[var(--accent)]/10 blur-[150px] animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      {/* Content Side */}
      <div class="relative">
        {showTagline && (
          <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--primary)]/10 border border-[var(--primary)]/20 mb-8">
            <span class="w-2 h-2 rounded-full bg-[var(--primary)] animate-ping"></span>
            <span class="text-[var(--fs-xs)] font-semibold tracking-wider uppercase text-[var(--primary)]">{badgeText}</span>
          </div>
        )}

        {showHeadline && (
          <h1 class="reveal-delay-1 reveal mb-8 leading-[1.05] font-bold tracking-tight text-[var(--text)]"
              style="font-size: var(--fs-display); font-family: var(--heading-font);">
            {headline}
          </h1>
        )}

        {showDescription && (
          <p class="reveal-delay-2 reveal mb-10 text-[var(--text-muted)] leading-relaxed max-w-xl"
             style="font-size: var(--fs-lg);">
            {description}
          </p>
        )}

        {showButton && (
          <div class="reveal-delay-3 reveal flex flex-wrap gap-4">
            <a href={ctaLink} 
               class="group relative inline-flex items-center justify-center px-8 py-4 font-bold text-[var(--text-inverse)] bg-[var(--primary)] rounded-2xl overflow-hidden transition-all duration-500 hover:scale-105 active:scale-95 shadow-xl shadow-[var(--primary)]/20">
              <span class="relative z-10">{ctaLabel}</span>
              <div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"></div>
            </a>
            <a href="#about" 
               class="inline-flex items-center justify-center px-8 py-4 font-bold text-[var(--text)] border-2 border-[var(--text)]/10 rounded-2xl transition-all duration-300 hover:bg-[var(--text)]/5">
              Learn Story
            </a>
          </div>
        )}
      </div>

      {/* Visual Side */}
      {showImage && (
        <div class="relative lg:h-[700px] flex items-center justify-center">
          {/* Main Image Frame */}
          <div class="reveal-delay-2 reveal relative w-full h-[400px] lg:h-full rounded-[40px] overflow-hidden shadow-2xl skew-y-1 transform-gpu hover:skew-y-0 transition-transform duration-700">
            {mainPhoto ? (
              <img src={mainPhoto} alt={businessName} class="w-full h-full object-cover scale-110 hover:scale-100 transition-transform duration-1000" />
            ) : (
              <div class="w-full h-full bg-gradient-to-tr from-[var(--secondary)] to-[var(--primary)]"></div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--secondary)]/40 to-transparent"></div>
          </div>

          {/* Floating Glass Card */}
          {showTestimonial && (
            <div class="reveal-delay-4 reveal absolute bottom-12 left-[-20px] lg:left-[-60px] max-w-[320px] p-8 glass-card rounded-3xl shadow-2xl border border-white/20 backdrop-blur-xl">
              <div class="flex gap-1 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-5 h-5 text-[var(--accent)] fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-[var(--text)] font-medium italic leading-relaxed">
                "{testimonial}"
              </p>
            </div>
          )}

          {/* Secondary Floating Image */}
          <div class="reveal-delay-3 reveal absolute top-[-40px] right-[-20px] w-32 h-32 lg:w-48 lg:h-48 rounded-full border-8 border-[var(--bg)] overflow-hidden shadow-2xl hidden md:block">
            <img src={secondaryPhoto} alt="" class="w-full h-full object-cover" />
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .glass-card {
    background: rgba(var(--surface-rgb, 255, 255, 255), 0.7);
  }

  /* Intersection Observer class from global.css will trigger .visible */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.2s; }
  .reveal-delay-2 { transition-delay: 0.4s; }
  .reveal-delay-3 { transition-delay: 0.6s; }
  .reveal-delay-4 { transition-delay: 0.8s; }
</style>
