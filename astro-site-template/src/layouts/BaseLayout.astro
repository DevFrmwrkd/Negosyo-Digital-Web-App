---
import '../styles/global.css';

interface Props {
  businessName: string;
  tagline: string;
  navLinks: Array<{ label: string; href: string }>;
  socialLinks?: Array<{ platform: string; url: string }>;
  colorScheme?: string;
  fontPairing?: string;
  contact?: {
    phone?: string;
    email?: string;
    address?: string;
  };
}

const {
  businessName,
  tagline,
  navLinks = [],
  socialLinks = [],
  colorScheme = 'auto',
  fontPairing = 'modern',
  contact = {},
} = Astro.props;

// Font pairings
const fontPairings: Record<string, { heading: string; body: string }> = {
  modern: { heading: 'Space Grotesk', body: 'Inter' },
  classic: { heading: 'Playfair Display', body: 'Source Sans Pro' },
  elegant: { heading: 'Cormorant Garamond', body: 'Montserrat' },
  bold: { heading: 'Bebas Neue', body: 'Roboto' },
  minimal: { heading: 'DM Sans', body: 'DM Sans' },
  professional: { heading: 'Poppins', body: 'Open Sans' },
  creative: { heading: 'Righteous', body: 'Nunito' },
  tech: { heading: 'Orbitron', body: 'Exo 2' },
  friendly: { heading: 'Quicksand', body: 'Quicksand' },
  luxury: { heading: 'Cinzel', body: 'Lato' },
};

const fonts = fontPairings[fontPairing] || fontPairings.modern;
const fontUrl = `https://fonts.googleapis.com/css2?family=${fonts.heading.replace(/ /g, '+')}:wght@300;400;500;600;700&family=${fonts.body.replace(/ /g, '+')}:wght@300;400;500;600&display=swap`;

// Color schemes
const colorSchemes: Record<string, { primary: string; secondary: string; accent: string; background: string; light: string }> = {
  auto: { primary: '#6B8F71', secondary: '#1F2933', accent: '#4ECDC4', background: '#F6F7F5', light: '#FFFFFF' },
  default: { primary: '#6B8F71', secondary: '#1F2933', accent: '#4ECDC4', background: '#F6F7F5', light: '#FFFFFF' },
  blue: { primary: '#3B82F6', secondary: '#1E3A8A', accent: '#60A5FA', background: '#EFF6FF', light: '#FFFFFF' },
  purple: { primary: '#8B5CF6', secondary: '#4C1D95', accent: '#A78BFA', background: '#F5F3FF', light: '#FFFFFF' },
  orange: { primary: '#F97316', secondary: '#7C2D12', accent: '#FB923C', background: '#FFF7ED', light: '#FFFFFF' },
  dark: { primary: '#D1D5DB', secondary: '#ffffff', accent: '#9CA3AF', background: '#111827', light: '#1a1a2e' },
};

const scheme = colorSchemes[colorScheme] || colorSchemes.auto;
const isDark = colorScheme === 'dark';

// Social SVG icons
const socialIcons: Record<string, string> = {
  instagram: '<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5M12 7a5 5 0 110 10 5 5 0 010-10m0 2a3 3 0 100 6 3 3 0 000-6z"/>',
  facebook: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  tiktok: '<path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>',
  twitter: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>',
  linkedin: '<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  youtube: '<path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75,15.02 15.5,11.75 9.75,8.48"/>',
};

const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={`${businessName} - ${tagline}`} />
  <meta property="og:title" content={`${businessName} - ${tagline}`} />
  <meta property="og:description" content={tagline} />
  <meta property="og:type" content="website" />
  <title>{businessName} - {tagline}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={fontUrl} rel="stylesheet" />
</head>
<body class="min-h-screen bg-white text-gray-900 antialiased" style={`font-family: '${fonts.body}', sans-serif;`}>
  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--nav-bg)] backdrop-blur-md border-b border-[var(--nav-border)]" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-18">
        <a href="#" class="text-lg font-semibold tracking-tight text-[var(--nav-text)]" style={`font-family: '${fonts.heading}', sans-serif;`}>
          {businessName}
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-8">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm font-medium text-[var(--nav-link)] hover:text-[var(--nav-text)] transition-colors">
              {link.label}
            </a>
          ))}
        </div>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="md:hidden flex flex-col gap-1.5 p-2"
          id="mobile-menu-btn"
          aria-label="Toggle menu"
        >
          <span class="block w-6 h-0.5 bg-[var(--nav-text)] transition-transform" id="menu-bar-1"></span>
          <span class="block w-6 h-0.5 bg-[var(--nav-text)] transition-opacity" id="menu-bar-2"></span>
          <span class="block w-6 h-0.5 bg-[var(--nav-text)] transition-transform" id="menu-bar-3"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div class="hidden md:hidden bg-[var(--nav-bg)] border-t border-[var(--nav-border)]" id="mobile-menu">
      <div class="px-4 py-4 space-y-3">
        {navLinks.map((link) => (
          <a href={link.href} class="block text-sm font-medium text-[var(--nav-link)] hover:text-[var(--nav-text)] py-2">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-[var(--footer-bg)] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        <!-- Brand -->
        <div>
          <h3 class="text-xl font-semibold mb-3" style={`font-family: '${fonts.heading}', sans-serif;`}>{businessName}</h3>
          <p class="text-sm text-white/60 leading-relaxed">{tagline}</p>
        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Quick Links</h4>
          <div class="space-y-2">
            {navLinks.map((link) => (
              <a href={link.href} class="block text-sm text-white/60 hover:text-white transition-colors">
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Social -->
        {socialLinks.length > 0 && (
          <div>
            <h4 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Follow Us</h4>
            <div class="flex gap-3">
              {socialLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
                  aria-label={link.platform}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={socialIcons[link.platform] || ''} />
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Copyright -->
      <div class="mt-10 pt-8 border-t border-white/10 text-center">
        <p class="text-xs text-white/40">&copy; {year} {businessName}. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <style define:vars={{
    'primary': scheme.primary,
    'secondary': scheme.secondary,
    'accent': scheme.accent,
    'bg': scheme.background,
    'light': scheme.light,
    'nav-bg': isDark ? 'rgba(17, 24, 39, 0.95)' : 'rgba(255, 255, 255, 0.95)',
    'nav-text': isDark ? '#ffffff' : '#1a1a1a',
    'nav-link': isDark ? 'rgba(255, 255, 255, 0.6)' : 'rgba(26, 26, 26, 0.6)',
    'nav-border': isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.08)',
    'footer-bg': isDark ? '#0a0a0f' : scheme.secondary,
    'heading-font': `'${fonts.heading}', sans-serif`,
    'body-font': `'${fonts.body}', sans-serif`,
  }}>
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--heading-font);
    }

    body, p, span, a, button, input, textarea, select {
      font-family: var(--body-font);
    }
  </style>

  <script>
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('menu-bar-1');
    const bar2 = document.getElementById('menu-bar-2');
    const bar3 = document.getElementById('menu-bar-3');

    if (btn && menu) {
      btn.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        if (!isOpen) {
          bar1?.style.setProperty('transform', 'rotate(45deg) translate(4px, 4px)');
          bar2?.style.setProperty('opacity', '0');
          bar3?.style.setProperty('transform', 'rotate(-45deg) translate(4px, -4px)');
        } else {
          bar1?.style.setProperty('transform', 'none');
          bar2?.style.setProperty('opacity', '1');
          bar3?.style.setProperty('transform', 'none');
        }
      });

      // Close menu on link click
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.add('hidden');
          bar1?.style.setProperty('transform', 'none');
          bar2?.style.setProperty('opacity', '1');
          bar3?.style.setProperty('transform', 'none');
        });
      });
    }

    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
